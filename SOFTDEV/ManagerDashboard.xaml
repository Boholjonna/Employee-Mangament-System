<Window x:Class="SOFTDEV.ManagerDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SOFTDEV"
        mc:Ignorable="d"
        Title="Manager Dashboard"
        MinWidth="1100" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="CanResize"
        Background="{StaticResource DarkBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"    />
        </Grid.RowDefinitions>

        <!-- ── Top Bar ── -->
        <DockPanel Grid.Row="0" Margin="20,10,20,8" LastChildFill="False">
            <Border DockPanel.Dock="Left"
                    Width="110" Height="48" CornerRadius="8"
                    Background="#1e1e2a" BorderBrush="#7b61ff" BorderThickness="1.5"
                    VerticalAlignment="Center">
                <TextBlock Text="LOGO" Foreground="#555566" FontSize="13" FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="SearchButton" Style="{StaticResource CircleButtonStyle}"
                        Content="🔍" Margin="0,0,8,0" Click="SearchButton_Click" />
                <Button x:Name="NotificationButton" Style="{StaticResource CircleButtonStyle}"
                        Content="🔔" Margin="0,0,8,0" Click="NotificationButton_Click" />
                <Button x:Name="UserNameButton" Style="{StaticResource PillButtonStyle}"
                        Width="90" Height="32" Margin="0,0,8,0" Click="UserNameButton_Click" />
                <Button x:Name="AvatarButton" Style="{StaticResource CircleButtonStyle}"
                        Content="👤" Click="AvatarButton_Click" />
            </StackPanel>
        </DockPanel>

        <!-- ── Nav Bar ── -->
        <UniformGrid Grid.Row="1" x:Name="NavBarPanel" Rows="1" Margin="20,0,20,14">
            <Button x:Name="OverviewButton" Style="{StaticResource PillButtonStyle}"
                    Margin="0,0,4,0" Click="NavButton_Click">
                <Button.Content>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="▲" Margin="0,0,4,0" />
                        <TextBlock Text="OVERVIEW" />
                    </StackPanel>
                </Button.Content>
            </Button>
            <Button x:Name="MyTeamButton" Style="{StaticResource PillButtonStyle}"
                    Content="My Team" Margin="4,0,4,0" Click="NavButton_Click" />
            <Button x:Name="AttendanceNavButton" Style="{StaticResource PillButtonStyle}"
                    Content="Attendance" Margin="4,0,4,0" Click="NavButton_Click" />
            <Button x:Name="ToDoButton" Style="{StaticResource PillButtonStyle}"
                    Content="To Do" Margin="4,0,4,0" Click="NavButton_Click" />
            <Button x:Name="ReportsButton" Style="{StaticResource PillButtonStyle}"
                    Content="Reports" Margin="4,0,4,0" Click="NavButton_Click" />
            <Button x:Name="LeavesButton" Style="{StaticResource PillButtonStyle}"
                    Content="Leaves" Margin="4,0,4,0" Click="NavButton_Click" />
            <Button x:Name="SettingsButton" Style="{StaticResource PillButtonStyle}"
                    Content="Settings" Margin="4,0,0,0" Click="NavButton_Click" />
        </UniformGrid>

        <!-- ── Main Content (Grid so panels can overlap/swap) ── -->
        <Grid Grid.Row="2">

            <!-- ════════════════════════════════════════════════════
                 PANEL A — Default Dashboard (first image)
                 ════════════════════════════════════════════════════ -->
            <ScrollViewer x:Name="DashboardPanel"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="Visible">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource CustomScrollbarStyle}" />
                </ScrollViewer.Resources>

                <Grid x:Name="MainContentGrid" Margin="20,0,20,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="0.9*" />
                        <ColumnDefinition Width="1.0*" />
                    </Grid.ColumnDefinitions>

                    <!-- ── LEFT COLUMN ── -->
                    <Grid Grid.Column="0" Margin="0,0,10,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" x:Name="GreetingText"
                                   Text="Hello Manager Name! 👋"
                                   Foreground="{StaticResource PurpleAccentBrush}"
                                   FontWeight="Bold" FontSize="20" Margin="0,0,0,14" />

                        <!-- 2×2 Stat Cards -->
                        <UniformGrid Grid.Row="1" Rows="2" Columns="2" Margin="0,0,0,14">
                            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Margin="4" Padding="18,16">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="total" Foreground="White" FontSize="14" />
                                        <TextBlock Text="of task" Foreground="White" FontSize="14" />
                                    </StackPanel>
                                    <Button Style="{StaticResource CircleButtonStyle}" Content="▶"
                                            Width="32" Height="32" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                            Click="TotalTaskCard_Click" />
                                </Grid>
                            </Border>
                            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Margin="4" Padding="18,16">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="message" Foreground="White" FontSize="14" />
                                        <TextBlock Text="team" Foreground="White" FontSize="14" />
                                    </StackPanel>
                                    <Button Style="{StaticResource CircleButtonStyle}" Content="▶"
                                            Width="32" Height="32" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                            Click="MessageTeamCard_Click" />
                                </Grid>
                            </Border>
                            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Margin="4" Padding="18,16">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="assign" Foreground="White" FontSize="14" />
                                        <TextBlock Text="task" Foreground="White" FontSize="14" />
                                    </StackPanel>
                                    <Button Style="{StaticResource CircleButtonStyle}" Content="▶"
                                            Width="32" Height="32" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                            Click="AssignTaskCard_Click" />
                                </Grid>
                            </Border>
                            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Margin="4" Padding="18,16">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="view" Foreground="White" FontSize="14" />
                                        <TextBlock Text="reports" Foreground="White" FontSize="14" />
                                    </StackPanel>
                                    <Button Style="{StaticResource CircleButtonStyle}" Content="▶"
                                            Width="32" Height="32" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                            Click="ViewReportsCard_Click" />
                                </Grid>
                            </Border>
                        </UniformGrid>

                        <!-- Attendance + Leave Approvals -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <!-- Attendance Panel -->
                            <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}"
                                    CornerRadius="12" Margin="4,0,6,0" Padding="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Margin="0,0,0,6">
                                        <TextBlock Text="Attendance" Foreground="{StaticResource PurpleAccentBrush}"
                                                   FontWeight="Bold" FontSize="14" />
                                        <Button Style="{StaticResource CircleButtonStyle}" Content="▶"
                                                Width="28" Height="28" HorizontalAlignment="Right"
                                                Click="AttendanceArrow_Click" />
                                    </Grid>
                                    <TextBlock Grid.Row="1" x:Name="AttendanceDateLabel"
                                               Foreground="#aaaaaa" FontSize="11" Margin="0,0,0,2" />
                                    <TextBlock Grid.Row="2" x:Name="ClockInTimeLabel"
                                               Text="--:-- --" Foreground="White" FontSize="18"
                                               FontWeight="Bold" Margin="0,0,0,6" />
                                    <TextBlock Grid.Row="3" x:Name="ClockInStatusLabel"
                                               Text="Clock In" Foreground="{StaticResource PurpleAccentBrush}"
                                               FontSize="12" Margin="0,0,0,10" />
                                    <StackPanel Grid.Row="4" Orientation="Vertical">
                                        <Button x:Name="ClockInOutButton" Style="{StaticResource PillButtonStyle}"
                                                Content="Clock IN / Clock OUT" FontSize="11" Padding="8,6"
                                                Margin="0,0,0,6" Click="ClockInOut_Click" />
                                        <Button x:Name="LunchBreakButton" Style="{StaticResource PillButtonStyle}"
                                                Content="LUNCH BREAK" FontSize="11" Padding="8,6"
                                                Click="LunchBreak_Click" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Leave Approvals Panel -->
                            <Border Grid.Column="1" Background="{StaticResource CardBackgroundBrush}"
                                    CornerRadius="12" Margin="6,0,4,0" Padding="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*"    />
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Margin="0,0,0,10">
                                        <TextBlock Text="Leave Approvals" Foreground="{StaticResource PurpleAccentBrush}"
                                                   FontWeight="Bold" FontSize="14" />
                                        <Button Style="{StaticResource CircleButtonStyle}" Content="▶"
                                                Width="28" Height="28" HorizontalAlignment="Right"
                                                Click="LeaveApprovalsArrow_Click" />
                                    </Grid>
                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*"    />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="52" Height="52" CornerRadius="26"
                                                Background="{StaticResource PurpleAccentBrush}" VerticalAlignment="Top">
                                            <TextBlock x:Name="LeaveApprovalDateLabel" Text="May&#x0a;23"
                                                       Foreground="White" FontSize="12" FontWeight="Bold"
                                                       TextAlignment="Center" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="10,0,6,0" VerticalAlignment="Top">
                                            <TextBlock x:Name="LeaveApprovalNameLabel" Text="Name"
                                                       Foreground="White" FontWeight="SemiBold" FontSize="13" />
                                            <TextBlock x:Name="LeaveApprovalPositionLabel" Text="member position"
                                                       Foreground="#888888" FontSize="11" Margin="0,2,0,6" />
                                            <TextBlock x:Name="LeaveApprovalReasonLabel" Text="reasonings and notes"
                                                       Foreground="#aaaaaa" FontSize="11" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <Border Grid.Column="2" Width="36" Height="20" CornerRadius="10"
                                                Background="{StaticResource PurpleAccentBrush}"
                                                VerticalAlignment="Top" Cursor="Hand">
                                            <TextBlock Text="✓" Foreground="White" FontSize="11"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- ── CENTER COLUMN — Calendar ── -->
                    <Grid Grid.Column="1" Margin="10,0,10,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text=" " FontSize="20" FontWeight="Bold"
                                   Margin="0,0,0,14" Visibility="Hidden" />
                        <Border Grid.Row="1" Background="{StaticResource CardBackgroundBrush}"
                                CornerRadius="12" Padding="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*"    />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="CalendarMonthLabel" Grid.Column="0"
                                            Style="{StaticResource PillButtonStyle}"
                                            Background="Transparent"
                                            Foreground="{StaticResource PurpleAccentBrush}"
                                            FontWeight="Bold" FontSize="16"
                                            HorizontalAlignment="Left" Padding="0"
                                            Click="CalendarMonthLabel_Click" />
                                    <Button x:Name="PrevMonthButton" Grid.Column="1"
                                            Style="{StaticResource CircleButtonStyle}"
                                            Content="◀" Width="32" Height="32"
                                            Margin="0,0,4,0" Click="PrevMonth_Click" />
                                    <Button x:Name="NextMonthButton" Grid.Column="2"
                                            Style="{StaticResource CircleButtonStyle}"
                                            Content="▶" Width="32" Height="32"
                                            Click="NextMonth_Click" />
                                </Grid>
                                <UniformGrid Grid.Row="1" x:Name="DayHeaderRow" Columns="7" Margin="0,0,0,6">
                                    <TextBlock Text="Sun" HorizontalAlignment="Center" Foreground="#aaaaaa" FontSize="12" />
                                    <TextBlock Text="Mon" HorizontalAlignment="Center" Foreground="#aaaaaa" FontSize="12" />
                                    <TextBlock Text="Tue" HorizontalAlignment="Center" Foreground="#aaaaaa" FontSize="12" />
                                    <TextBlock Text="Wed" HorizontalAlignment="Center" Foreground="#aaaaaa" FontSize="12" />
                                    <TextBlock Text="Thu" HorizontalAlignment="Center" Foreground="#aaaaaa" FontSize="12" />
                                    <TextBlock Text="Fri" HorizontalAlignment="Center" Foreground="#aaaaaa" FontSize="12" />
                                    <TextBlock Text="Sat" HorizontalAlignment="Center" Foreground="#aaaaaa" FontSize="12" />
                                </UniformGrid>
                                <ItemsControl Grid.Row="2" x:Name="CalendarDaysControl">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="7" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Margin="2" Padding="0" Background="Transparent"
                                                    BorderThickness="0" Cursor="Hand"
                                                    Tag="{Binding Day}" Click="CalendarDay_Click">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="DayBorder"
                                                                            Background="{TemplateBinding Background}"
                                                                            CornerRadius="18" Padding="2">
                                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                                          VerticalAlignment="Center" />
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="DayBorder" Property="Background" Value="#44ffffff" />
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource PurpleAccentBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Background" Value="#9b7fe8" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <TextBlock Text="{Binding Day}" FontSize="13"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           MinWidth="26" MinHeight="26" TextAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="White" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Day}" Value="0">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                                    <Setter Property="Foreground" Value="#1a1a2e" />
                                                                    <Setter Property="FontWeight" Value="ExtraBold" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Grid.Row="3" x:Name="LiveClockLabel"
                                           Foreground="#aaaaaa" FontSize="12"
                                           HorizontalAlignment="Center" Margin="0,10,0,0" />
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ── RIGHT COLUMN — My Team ── -->
                    <Grid Grid.Column="2" Margin="10,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*"    />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text=" " FontSize="20" FontWeight="Bold"
                                   Margin="0,0,0,14" Visibility="Hidden" />
                        <Border Grid.Row="1" Background="{StaticResource CardBackgroundBrush}"
                                CornerRadius="12" Padding="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*"    />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="My Team"
                                           Foreground="{StaticResource PurpleAccentBrush}"
                                           FontWeight="Bold" FontSize="16" Margin="0,0,0,14" />
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled" MaxHeight="380">
                                    <ScrollViewer.Resources>
                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource CustomScrollbarStyle}" />
                                    </ScrollViewer.Resources>
                                    <ItemsControl x:Name="TeamMembersList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*"    />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Width="40" Height="40"
                                                            CornerRadius="20" Background="#2a2a3e"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="👤" FontSize="18"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" Foreground="White"
                                                                   FontWeight="SemiBold" FontSize="13" />
                                                        <TextBlock Text="{Binding Position}" Foreground="#888888" FontSize="11" />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                <Button Grid.Row="2" Style="{StaticResource CircleButtonStyle}"
                                        Content="▶" Width="32" Height="32"
                                        HorizontalAlignment="Right" Margin="0,10,0,0"
                                        Click="MyTeamArrow_Click" />
                            </Grid>
                        </Border>
                    </Grid>

                </Grid>
            </ScrollViewer>

            <!-- ════════════════════════════════════════════════════
                 PANEL B — Overview Charts (second image)
                 Shown when OVERVIEW nav button is clicked
                 ════════════════════════════════════════════════════ -->
            <ScrollViewer x:Name="OverviewPanel"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="Collapsed">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource CustomScrollbarStyle}" />
                </ScrollViewer.Resources>

                <StackPanel Margin="20,0,20,20">

                    <!-- Greeting (mirrors dashboard greeting) -->
                    <TextBlock x:Name="OverviewGreetingText"
                               Text="Hello Manager Name! 👋"
                               Foreground="{StaticResource PurpleAccentBrush}"
                               FontWeight="Bold" FontSize="20" Margin="0,0,0,16" />

                    <!-- Two chart cards -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.42*" />
                            <ColumnDefinition Width="0.58*" />
                        </Grid.ColumnDefinitions>

                        <!-- ── CARD 1: Task Overview (Donut) ── -->
                        <Border Grid.Column="0"
                                Background="{StaticResource CardBackgroundBrush}"
                                CornerRadius="14" Margin="0,0,10,0" Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*"    />
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,16">
                                    <TextBlock Text="TASK OVERVIEW" Foreground="White"
                                               FontWeight="Bold" FontSize="15" VerticalAlignment="Center" />
                                    <Button Style="{StaticResource CircleButtonStyle}" Content="▶"
                                            Width="32" Height="32" HorizontalAlignment="Right"
                                            Click="TaskOverviewArrow_Click" />
                                </Grid>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"    />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Viewbox Grid.Column="0" Width="200" Height="200"
                                             HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Canvas x:Name="DonutCanvas" Width="200" Height="200" />
                                    </Viewbox>
                                    <!-- Legend -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <Ellipse Width="12" Height="12" Fill="#7b61ff" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <StackPanel>
                                                <TextBlock Text="Done" Foreground="White" FontSize="12" />
                                                <TextBlock Text="55%" Foreground="#aaaaaa" FontSize="11" />
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <Ellipse Width="12" Height="12" Fill="#9b7fe8" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <StackPanel>
                                                <TextBlock Text="In-progress" Foreground="White" FontSize="12" />
                                                <TextBlock Text="25%" Foreground="#aaaaaa" FontSize="11" />
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <Ellipse Width="12" Height="12" Fill="#4a90d9" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <StackPanel>
                                                <TextBlock Text="Late" Foreground="White" FontSize="12" />
                                                <TextBlock Text="15%" Foreground="#aaaaaa" FontSize="11" />
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="12" Height="12" Fill="#e8c84a" VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <StackPanel>
                                                <TextBlock Text="Other" Foreground="White" FontSize="12" />
                                                <TextBlock Text="5%" Foreground="#aaaaaa" FontSize="11" />
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- ── CARD 2: Employee Performances (Line Chart) ── -->
                        <Border Grid.Column="1"
                                Background="{StaticResource CardBackgroundBrush}"
                                CornerRadius="14" Margin="10,0,0,0" Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="260"  />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <TextBlock Text="EMPLOYEE PERFORMANCES" Foreground="White"
                                               FontWeight="Bold" FontSize="15" VerticalAlignment="Center" />
                                    <Button Style="{StaticResource CircleButtonStyle}" Content="▶"
                                            Width="32" Height="32" HorizontalAlignment="Right"
                                            Click="EmpPerfArrow_Click" />
                                </Grid>

                                <!-- Legend -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="44,0,0,8">
                                    <Ellipse Width="10" Height="10" Fill="#4a90d9" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBlock Text="Mobile" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="0,0,20,0" />
                                    <Ellipse Width="10" Height="10" Fill="#9b7fe8" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBlock Text="Desktop" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="0,0,20,0" />
                                    <Ellipse Width="10" Height="10" Fill="#e8c84a" VerticalAlignment="Center" Margin="0,0,6,0" />
                                </StackPanel>

                                <!-- Chart area -->
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*"  />
                                    </Grid.ColumnDefinitions>
                                    <Canvas Grid.Column="0" x:Name="YAxisCanvas" />
                                    <Canvas Grid.Column="1" x:Name="LineChartCanvas" ClipToBounds="True" />
                                </Grid>

                                <!-- X-axis labels + bottom arrow -->
                                <Grid Grid.Row="3" Margin="0,4,0,0">
                                    <Grid Margin="40,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
