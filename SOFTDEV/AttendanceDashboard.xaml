<Window x:Class="SOFTDEV.AttendanceDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SOFTDEV"
        mc:Ignorable="d"
        Title="Attendance Dashboard"
        MinWidth="1200"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="CanResize"
        Background="{StaticResource DarkBackgroundBrush}"
        FontFamily="Segoe UI">

    <!-- ═══════════════════════════════════════════════════════════
         Top-level Grid: Row 0 = header/nav (Auto), Row 1 = content (*)
         ═══════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Row 0: Header + Nav Bar -->
            <RowDefinition Height="*"    />  <!-- Row 1: Main Content     -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             Row 0 — Header Section (top bar + nav bar)
             ═══════════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="0" Orientation="Vertical">

            <!-- ─────────────────────────────────────────────────
                 TopNavBar — company logo left, control group right
                 ───────────────────────────────────────────────── -->
            <DockPanel Margin="20,16,20,8" LastChildFill="False">

                <!-- Left: Back button + Company name / logo -->
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Button x:Name="BackButton"
                            Style="{StaticResource CircleButtonStyle}"
                            Content="←"
                            Margin="0,0,12,0"
                            Click="BackButton_Click" />

                    <TextBlock Text="COMPANY NAME/LOGO"
                               Foreground="{StaticResource PurpleAccentBrush}"
                               FontWeight="Bold"
                               FontSize="18"
                               VerticalAlignment="Center" />

                </StackPanel>

                <!-- Right: Search, Notifications, Username, Avatar -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Button x:Name="SearchButton"
                            Style="{StaticResource CircleButtonStyle}"
                            Content="🔍"
                            Margin="0,0,8,0"
                            Click="SearchButton_Click" />

                    <Button x:Name="NotificationButton"
                            Style="{StaticResource CircleButtonStyle}"
                            Content="🔔"
                            Margin="0,0,8,0"
                            Click="NotificationButton_Click" />

                    <Button x:Name="UserNameButton"
                            Style="{StaticResource PillButtonStyle}"
                            Content="NAME"
                            Width="80"
                            Height="30"
                            Margin="0,0,8,0"
                            Click="UserNameButton_Click" />

                    <Button x:Name="AvatarButton"
                            Style="{StaticResource CircleButtonStyle}"
                            Content="👤"
                            Click="AvatarButton_Click" />

                </StackPanel>

            </DockPanel>

            <!-- ─────────────────────────────────────────────────
                 Navigation Bar — 7 equal-width buttons
                 ───────────────────────────────────────────────── -->
            <UniformGrid x:Name="NavBarPanel"
                         Rows="1"
                         Margin="20,0,20,16">

                <!-- Overview — inactive -->
                <Button x:Name="OverviewButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="▲ OVERVIEW"
                        Background="{StaticResource PurpleAccentBrush}"
                        Opacity="0.4"
                        Margin="0,0,4,0"
                        Click="NavButton_Click">
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="Button.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="1.0" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Button.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="0.4" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>

                <!-- Employees — inactive -->
                <Button x:Name="EmployeesButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="Employees"
                        Background="{StaticResource PurpleAccentBrush}"
                        Opacity="0.4"
                        Margin="4,0,4,0"
                        Click="NavButton_Click">
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="Button.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="1.0" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Button.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="0.4" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>

                <!-- Attendance — ACTIVE tab -->
                <Button x:Name="AttendanceButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="Attendance"
                        Background="{StaticResource PurpleAccentBrush}"
                        Opacity="1.0"
                        Margin="4,0,4,0"
                        Click="NavButton_Click" />

                <!-- Task Management — inactive -->
                <Button x:Name="ToDoButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="Task Management"
                        Background="{StaticResource PurpleAccentBrush}"
                        Opacity="0.4"
                        Margin="4,0,4,0"
                        Click="NavButton_Click">
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="Button.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="1.0" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Button.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="0.4" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>

                <!-- Reports — inactive -->
                <Button x:Name="ReportsButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="Reports"
                        Background="{StaticResource PurpleAccentBrush}"
                        Opacity="0.4"
                        Margin="4,0,4,0"
                        Click="NavButton_Click">
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="Button.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="1.0" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Button.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="0.4" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>

                <!-- Leaves — inactive -->
                <Button x:Name="LeavesButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="Leaves"
                        Background="{StaticResource PurpleAccentBrush}"
                        Opacity="0.4"
                        Margin="4,0,4,0"
                        Click="NavButton_Click">
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="Button.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="1.0" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Button.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="0.4" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>

                <!-- Settings — inactive -->
                <Button x:Name="SettingsButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="Settings"
                        Background="{StaticResource PurpleAccentBrush}"
                        Opacity="0.4"
                        Margin="4,0,0,0"
                        Click="NavButton_Click">
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="Button.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="1.0" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Button.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="0.4" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>

            </UniformGrid>

        </StackPanel>

        <!-- ═══════════════════════════════════════════════════════════
             Row 1 — Main Content Area
             ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="20,0,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- Row 0: Greeting TextBlock -->
                <RowDefinition Height="*"    />  <!-- Row 1: Main card           -->
            </Grid.RowDefinitions>

            <!-- ─────────────────────────────────────────────────
                 Greeting TextBlock
                 ───────────────────────────────────────────────── -->
            <TextBlock Grid.Row="0"
                       Text="{Binding AdminGreeting}"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,12" />

            <!-- ─────────────────────────────────────────────────
                 Main card container
                 ───────────────────────────────────────────────── -->
            <Border Grid.Row="1"
                    CornerRadius="30"
                    Background="#1a1a2e"
                    Padding="24">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />  <!-- Row 0: Content header -->
                        <RowDefinition Height="Auto" />  <!-- Row 1: Column headers  -->
                        <RowDefinition Height="*"    />  <!-- Row 2: Data area        -->
                    </Grid.RowDefinitions>

                    <!-- ─────────────────────────────────────────────────
                         Row 0 — Content Header: title left, buttons right
                         ───────────────────────────────────────────────── -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"    />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="ATTENDANCE"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="20"
                                   VerticalAlignment="Center" />

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">

                            <Button x:Name="FilterButton"
                                    Style="{StaticResource PillButtonStyle}"
                                    Content="FILTER ↓"
                                    MinWidth="100"
                                    Padding="16,8"
                                    Margin="0,0,8,0"
                                    Click="FilterButton_Click" />

                            <Button x:Name="SortButton"
                                    Style="{StaticResource PillButtonStyle}"
                                    Content="SORT ↓"
                                    MinWidth="90"
                                    Padding="16,8"
                                    Click="SortButton_Click" />

                        </StackPanel>
                    </Grid>

                    <!-- ─────────────────────────────────────────────────
                         Row 1 — Column Header Row
                         ───────────────────────────────────────────────── -->
                    <Border Grid.Row="1"
                            Background="#2a2a3e"
                            CornerRadius="8"
                            Padding="8,10"
                            Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"   />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="1*"   />
                                <ColumnDefinition Width="1*"   />
                                <ColumnDefinition Width="1*"   />
                                <ColumnDefinition Width="1.2*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="EMPLOYEE"    FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource PurpleAccentBrush}" />
                            <TextBlock Grid.Column="1" Text="DATE"        FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource PurpleAccentBrush}" />
                            <TextBlock Grid.Column="2" Text="TIME IN"     FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource PurpleAccentBrush}" />
                            <TextBlock Grid.Column="3" Text="TIME OUT"    FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource PurpleAccentBrush}" />
                            <TextBlock Grid.Column="4" Text="TOTAL HOURS" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource PurpleAccentBrush}" />
                            <TextBlock Grid.Column="5" Text="STATUS"      FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource PurpleAccentBrush}" />
                        </Grid>
                    </Border>

                    <!-- ─────────────────────────────────────────────────
                         Row 2 — Scrollable Data Area + Popups (Grid overlay)
                         ───────────────────────────────────────────────── -->
                    <Grid Grid.Row="2">

                        <!-- Data ScrollViewer -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ScrollViewer.Resources>
                                <Style TargetType="ScrollBar"
                                       BasedOn="{StaticResource CustomScrollbarStyle}" />
                            </ScrollViewer.Resources>

                            <Grid>
                                <!-- ItemsControl bound to AttendanceRecords -->
                                <ItemsControl x:Name="DataGrid_ItemsControl"
                                              ItemsSource="{Binding AttendanceRecords}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*"   />
                                                    <ColumnDefinition Width="1.5*" />
                                                    <ColumnDefinition Width="1*"   />
                                                    <ColumnDefinition Width="1*"   />
                                                    <ColumnDefinition Width="1*"   />
                                                    <ColumnDefinition Width="1.2*" />
                                                </Grid.ColumnDefinitions>

                                                <!-- EMPLOYEE -->
                                                <Border Grid.Column="0" CornerRadius="8" Background="#2a2a3e" Margin="4,2">
                                                    <TextBlock Text="{Binding EmployeeName}" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="8,6" TextWrapping="Wrap" />
                                                </Border>

                                                <!-- DATE -->
                                                <Border Grid.Column="1" CornerRadius="8" Background="#2a2a3e" Margin="4,2">
                                                    <TextBlock Text="{Binding Date}" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="8,6" />
                                                </Border>

                                                <!-- TIME IN -->
                                                <Border Grid.Column="2" CornerRadius="8" Background="#2a2a3e" Margin="4,2">
                                                    <TextBlock Text="{Binding TimeIn}" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="8,6" />
                                                </Border>

                                                <!-- TIME OUT -->
                                                <Border Grid.Column="3" CornerRadius="8" Background="#2a2a3e" Margin="4,2">
                                                    <TextBlock Text="{Binding TimeOut}" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="8,6" />
                                                </Border>

                                                <!-- TOTAL HOURS -->
                                                <Border Grid.Column="4" CornerRadius="8" Background="#2a2a3e" Margin="4,2">
                                                    <TextBlock Text="{Binding TotalHours}" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="8,6" />
                                                </Border>

                                                <!-- STATUS badge -->
                                                <Border Grid.Column="5" Margin="4,2" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        CornerRadius="12" Padding="10,4"
                                                        Background="{Binding StatusColor}">
                                                    <TextBlock Text="{Binding Status}" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" />
                                                </Border>

                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Empty-state message — visible only when AttendanceRecords is empty -->
                                <TextBlock x:Name="EmptyStateTextBlock"
                                           Text="No attendance records found."
                                           Foreground="#aaaaaa"
                                           FontSize="15"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="0,40">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AttendanceRecords.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                            </Grid>
                        </ScrollViewer>

                        <!-- ─────────────────────────────────────────────────
                             FilterPopup overlay (collapsed by default)
                             ───────────────────────────────────────────────── -->
                        <Border x:Name="FilterPopup"
                                Visibility="Collapsed"
                                Background="#1a1a2e"
                                CornerRadius="16"
                                Padding="20"
                                Width="320"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,4,4,0"
                                Panel.ZIndex="10">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="16" Opacity="0.5" ShadowDepth="4" />
                            </Border.Effect>
                            <StackPanel Orientation="Vertical">

                                <TextBlock Text="Filter Records"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           FontSize="16"
                                           Margin="0,0,0,16" />

                                <!-- From Date -->
                                <TextBlock Text="From Date" Foreground="#aaaaaa" FontSize="12" Margin="0,0,0,4" />
                                <DatePicker x:Name="FilterFromDate"
                                            Margin="0,0,0,12"
                                            Background="#2a2a3e"
                                            Foreground="White" />

                                <!-- To Date -->
                                <TextBlock Text="To Date" Foreground="#aaaaaa" FontSize="12" Margin="0,0,0,4" />
                                <DatePicker x:Name="FilterToDate"
                                            Margin="0,0,0,12"
                                            Background="#2a2a3e"
                                            Foreground="White" />

                                <!-- Employee -->
                                <TextBlock Text="Employee" Foreground="#aaaaaa" FontSize="12" Margin="0,0,0,4" />
                                <TextBox x:Name="FilterEmployeeText"
                                         Style="{StaticResource RoundedTextBoxStyle}"
                                         Margin="0,0,0,12" />

                                <!-- Status -->
                                <TextBlock Text="Status" Foreground="#aaaaaa" FontSize="12" Margin="0,0,0,4" />
                                <ComboBox x:Name="FilterStatusCombo"
                                          Margin="0,0,0,16"
                                          Background="#2a2a3e"
                                          Foreground="White">
                                    <ComboBoxItem Content="All" IsSelected="True" />
                                    <ComboBoxItem Content="Present" />
                                    <ComboBoxItem Content="Late" />
                                    <ComboBoxItem Content="Absent" />
                                    <ComboBoxItem Content="On Leave" />
                                </ComboBox>

                                <!-- Apply / Reset buttons -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Style="{StaticResource PillButtonStyle}"
                                            Content="Apply"
                                            Padding="16,8"
                                            Margin="0,0,8,0"
                                            Click="ApplyFilter_Click" />
                                    <Button Style="{StaticResource OutlinePillButtonStyle}"
                                            Content="Reset"
                                            Padding="16,8"
                                            Click="ResetFilter_Click" />
                                </StackPanel>

                            </StackPanel>
                        </Border>

                        <!-- ─────────────────────────────────────────────────
                             SortPopup overlay (collapsed by default)
                             ───────────────────────────────────────────────── -->
                        <Border x:Name="SortPopup"
                                Visibility="Collapsed"
                                Background="#1a1a2e"
                                CornerRadius="16"
                                Padding="20"
                                Width="260"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,4,4,0"
                                Panel.ZIndex="10">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="16" Opacity="0.5" ShadowDepth="4" />
                            </Border.Effect>
                            <StackPanel Orientation="Vertical">

                                <TextBlock Text="Sort By"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           FontSize="16"
                                           Margin="0,0,0,12" />

                                <ComboBox x:Name="SortColumnCombo"
                                          Margin="0,0,0,12"
                                          Background="#2a2a3e"
                                          Foreground="White">
                                    <ComboBoxItem Content="Employee Name" IsSelected="True" />
                                    <ComboBoxItem Content="Date" />
                                    <ComboBoxItem Content="Time In" />
                                    <ComboBoxItem Content="Time Out" />
                                    <ComboBoxItem Content="Total Hours" />
                                    <ComboBoxItem Content="Status" />
                                </ComboBox>

                                <TextBlock Text="Direction"
                                           Foreground="#aaaaaa"
                                           FontSize="12"
                                           Margin="0,0,0,8" />

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <RadioButton x:Name="SortAscending"
                                                 Content="Ascending"
                                                 IsChecked="True"
                                                 Foreground="White"
                                                 Margin="0,0,16,0" />
                                    <RadioButton x:Name="SortDescending"
                                                 Content="Descending"
                                                 Foreground="White" />
                                </StackPanel>

                                <Button Style="{StaticResource PillButtonStyle}"
                                        Content="Apply Sort"
                                        Padding="16,8"
                                        HorizontalAlignment="Stretch"
                                        Click="ApplySort_Click" />

                            </StackPanel>
                        </Border>

                    </Grid>

                </Grid>
            </Border>

        </Grid>

    </Grid>

</Window>
