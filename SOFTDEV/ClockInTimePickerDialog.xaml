<Window x:Class="SOFTDEV.ClockInTimePickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Clock-In Time"
        Width="320"
        Height="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource DarkBackgroundBrush}"
        FontFamily="Segoe UI">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Title -->
            <RowDefinition Height="*"    />  <!-- Time picker -->
            <RowDefinition Height="Auto" />  <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Select Clock-In Time"
                   Foreground="{StaticResource PurpleAccentBrush}"
                   FontWeight="Bold"
                   FontSize="16"
                   Margin="0,0,0,20" />

        <!-- Time picker: HH : MM  AM/PM -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <!-- Hour spinner -->
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <Button x:Name="HourUpButton"
                        Style="{StaticResource CircleButtonStyle}"
                        Content="▲"
                        HorizontalAlignment="Center"
                        Click="HourUp_Click" />
                <TextBlock x:Name="HourDisplay"
                           Text="08"
                           Foreground="White"
                           FontSize="36"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,4" />
                <Button x:Name="HourDownButton"
                        Style="{StaticResource CircleButtonStyle}"
                        Content="▼"
                        HorizontalAlignment="Center"
                        Click="HourDown_Click" />
            </StackPanel>

            <!-- Colon separator -->
            <TextBlock Text=":"
                       Foreground="White"
                       FontSize="36"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="10,0,10,0" />

            <!-- Minute spinner -->
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <Button x:Name="MinuteUpButton"
                        Style="{StaticResource CircleButtonStyle}"
                        Content="▲"
                        HorizontalAlignment="Center"
                        Click="MinuteUp_Click" />
                <TextBlock x:Name="MinuteDisplay"
                           Text="00"
                           Foreground="White"
                           FontSize="36"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,4" />
                <Button x:Name="MinuteDownButton"
                        Style="{StaticResource CircleButtonStyle}"
                        Content="▼"
                        HorizontalAlignment="Center"
                        Click="MinuteDown_Click" />
            </StackPanel>

            <!-- AM / PM toggle -->
            <StackPanel Orientation="Vertical"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                <Button x:Name="AmButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="AM"
                        Width="52"
                        Height="32"
                        Margin="0,0,0,6"
                        Click="AmPm_Click" />
                <Button x:Name="PmButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="PM"
                        Width="52"
                        Height="32"
                        Opacity="0.4"
                        Click="AmPm_Click" />
            </StackPanel>

        </StackPanel>

        <!-- Confirm / Cancel buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">

            <Button x:Name="CancelButton"
                    Style="{StaticResource PillButtonStyle}"
                    Content="Cancel"
                    Width="80"
                    Opacity="0.5"
                    Margin="0,0,8,0"
                    Click="Cancel_Click" />

            <Button x:Name="ConfirmButton"
                    Style="{StaticResource PillButtonStyle}"
                    Content="Confirm"
                    Width="80"
                    Click="Confirm_Click" />

        </StackPanel>

    </Grid>
</Window>
