<Window x:Class="SOFTDEV.AdminDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SOFTDEV"
        mc:Ignorable="d"
        Title="Admin Dashboard"
        MinWidth="1200"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="CanResize"
        Background="{StaticResource DarkBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Row 0: Header Section -->
            <RowDefinition Height="*"    />  <!-- Row 1: Main Content   -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             Row 0 — Header Section
             ═══════════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="0" Orientation="Vertical">

            <!-- ─────────────────────────────────────────────────
                 Control Group (logo left, search/bell/user/avatar right)
                 ───────────────────────────────────────────────── -->
            <DockPanel Margin="20,16,20,8" LastChildFill="False">

                <!-- Left: Nexis Corp. logo -->
                <Image DockPanel.Dock="Left"
                       Source="/images/nexis_logo.png"
                       Height="40"
                       Width="Auto"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality" />

                <!-- Right: Search, Notifications, Username, Avatar -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                <Button x:Name="SearchButton"
                        Style="{StaticResource CircleButtonStyle}"
                        Content="🔍"
                        Margin="0,0,8,0"
                        Click="SearchButton_Click" />

                <Button x:Name="NotificationButton"
                        Style="{StaticResource CircleButtonStyle}"
                        Content="🔔"
                        Margin="0,0,8,0"
                        Click="NotificationButton_Click" />

                <Button x:Name="UserNameButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="NAME"
                        Width="80"
                        Height="30"
                        Margin="0,0,8,0"
                        Click="UserNameButton_Click" />

                <Button x:Name="AvatarButton"
                        Style="{StaticResource CircleButtonStyle}"
                        Content="👤"
                        Click="AvatarButton_Click" />

                </StackPanel>
            </DockPanel>

            <!-- ─────────────────────────────────────────────────
                 Navigation Bar — equal-width buttons spanning full width
                 ───────────────────────────────────────────────── -->
            <UniformGrid x:Name="NavBarPanel"
                         Rows="1"
                         Margin="20,0,20,16">

                <!-- Overview (icon + label) -->
                <Button x:Name="OverviewButton"
                        Style="{StaticResource PillButtonStyle}"
                        Margin="0,0,4,0"
                        Click="NavButton_Click">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="▲" Margin="0,0,4,0" />
                            <TextBlock Text="OVERVIEW" />
                        </StackPanel>
                    </Button.Content>
                </Button>

                <Button x:Name="EmployeesButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="Employees"
                        Margin="4,0,4,0"
                        Click="NavButton_Click" />

                <Button x:Name="AttendanceButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="Attendance"
                        Margin="4,0,4,0"
                        Click="NavButton_Click" />

                <Button x:Name="ToDoButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="Task Management"
                        Margin="4,0,4,0"
                        Click="NavButton_Click" />

                <Button x:Name="ReportsButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="Reports"
                        Margin="4,0,4,0"
                        Click="NavButton_Click" />

                <Button x:Name="LeavesButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="Leaves"
                        Margin="4,0,4,0"
                        Click="NavButton_Click" />

                <Button x:Name="SettingsButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="Settings"
                        Margin="4,0,0,0"
                        Click="NavButton_Click" />

            </UniformGrid>

        </StackPanel>

        <!-- ═══════════════════════════════════════════════════════════
             Row 1 — Main Content Area (wrapped in ScrollViewer)
             ═══════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar"
                       BasedOn="{StaticResource CustomScrollbarStyle}" />
            </ScrollViewer.Resources>

        <Grid x:Name="MainContentGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />  <!-- Left: stats + attendance/leave -->
                <ColumnDefinition Width="0.9*" />  <!-- Center: calendar -->
                <ColumnDefinition Width="1.2*" />  <!-- Right: employee list -->
            </Grid.ColumnDefinitions>

            <!-- ─────────────────────────────────────────────────
                 Column 0 — Left Column (Grid layout)
                 ───────────────────────────────────────────────── -->
            <Grid Grid.Column="0" Margin="20,0,10,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />  <!-- Row 0: Greeting -->
                    <RowDefinition Height="Auto" />  <!-- Row 1: Stats (2×2) -->
                    <RowDefinition Height="Auto" />  <!-- Row 2: Attendance + Leave Approvals -->
                </Grid.RowDefinitions>

                <!-- Row 0: Greeting -->
                <TextBlock Grid.Row="0"
                           x:Name="GreetingText"
                           Text="Hello Admin Name! 👋"
                           Foreground="{StaticResource PurpleAccentBrush}"
                           FontWeight="Bold"
                           FontSize="22"
                           Margin="0,0,0,16" />

                <!-- Row 1: Stats Grid (2×2) -->
                <UniformGrid Grid.Row="1"
                             x:Name="StatsGrid"
                             Rows="2"
                             Columns="2"
                             Margin="0,0,0,16">

                    <!-- StatCard0: Number of Employees (clickable → Employees view) -->
                    <Border x:Name="StatCard0"
                            Background="{StaticResource CardBackgroundBrush}"
                            CornerRadius="12"
                            Margin="4"
                            Padding="20"
                            Cursor="Hand"
                            MouseLeftButtonUp="StatCard0_Click">
                        <StackPanel>
                            <TextBlock Text="Number of Employees"
                                       Foreground="{StaticResource PurpleAccentBrush}"
                                       FontSize="13"
                                       FontWeight="Bold" />
                            <TextBlock x:Name="EmployeeCountLabel"
                                       Text="—"
                                       Foreground="White"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Margin="0,6,0,0" />
                            <Button Style="{StaticResource CircleButtonStyle}"
                                    Content="↻"
                                    HorizontalAlignment="Right"
                                    Click="StatCardRefresh_Click" />
                        </StackPanel>
                    </Border>

                    <!-- StatCard1: On Leave -->
                    <Border x:Name="StatCard1"
                            Background="{StaticResource CardBackgroundBrush}"
                            CornerRadius="12"
                            Margin="4"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="On Leave"
                                       Foreground="{StaticResource PurpleAccentBrush}"
                                       FontSize="13"
                                       FontWeight="Bold" />
                            <Button Style="{StaticResource CircleButtonStyle}"
                                    Content="↻"
                                    HorizontalAlignment="Right"
                                    Click="StatCardRefresh_Click" />
                        </StackPanel>
                    </Border>

                    <!-- StatCard2: New Joinee -->
                    <Border x:Name="StatCard2"
                            Background="{StaticResource CardBackgroundBrush}"
                            CornerRadius="12"
                            Margin="4"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="New Joinee"
                                       Foreground="{StaticResource PurpleAccentBrush}"
                                       FontSize="13"
                                       FontWeight="Bold" />
                            <Button Style="{StaticResource CircleButtonStyle}"
                                    Content="↻"
                                    HorizontalAlignment="Right"
                                    Click="StatCardRefresh_Click" />
                        </StackPanel>
                    </Border>

                    <!-- StatCard3: Work Holidays / Others -->
                    <Border x:Name="StatCard3"
                            Background="{StaticResource CardBackgroundBrush}"
                            CornerRadius="12"
                            Margin="4"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="Work Holidays / Others"
                                       Foreground="{StaticResource PurpleAccentBrush}"
                                       FontSize="13"
                                       FontWeight="Bold" />
                            <Button Style="{StaticResource CircleButtonStyle}"
                                    Content="↻"
                                    HorizontalAlignment="Right"
                                    Click="StatCardRefresh_Click" />
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <!-- Row 2: Attendance + Leave Approvals (side by side) -->
                <Grid Grid.Row="2" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Attendance Panel -->
                    <Border Grid.Column="0"
                            x:Name="AttendancePanel"
                            Background="{StaticResource CardBackgroundBrush}"
                            CornerRadius="12"
                            Margin="4,0,8,0"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="Attendance"
                                       Foreground="{StaticResource PurpleAccentBrush}"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Margin="0,0,0,12" />
                            <TextBlock x:Name="AttendanceDateLabel"
                                       Foreground="White"
                                       FontSize="14"
                                       Margin="0,0,0,4" />
                            <!-- Shows the selected clock-in time; updates after picker confirms -->
                            <TextBlock x:Name="ClockInTimeLabel"
                                       Text="--:-- --"
                                       Foreground="White"
                                       FontSize="14"
                                       Margin="0,0,0,8" />
                            <TextBlock x:Name="ClockInStatusLabel"
                                       Text="Not clocked in"
                                       Foreground="{StaticResource PurpleAccentBrush}"
                                       FontSize="13"
                                       Margin="0,0,0,12" />
                            <StackPanel Orientation="Vertical">
                                <Button x:Name="ClockInOutButton"
                                        Style="{StaticResource PillButtonStyle}"
                                        Content="Clock IN/OUT"
                                        Margin="0,0,0,8"
                                        Click="ClockInOut_Click" />
                                <Button x:Name="LunchBreakButton"
                                        Style="{StaticResource PillButtonStyle}"
                                        Content="LUNCH BREAK"
                                        Click="LunchBreak_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Leave Approvals Panel -->
                    <Border Grid.Column="1"
                            x:Name="LeaveApprovalsPanel"
                            Background="{StaticResource CardBackgroundBrush}"
                            CornerRadius="12"
                            Margin="8,0,4,0"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="Leave Approvals"
                                       Foreground="{StaticResource PurpleAccentBrush}"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Margin="0,0,0,16" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Circle highlight -->
                                <Border Grid.Column="0"
                                        Width="64"
                                        Height="64"
                                        CornerRadius="32"
                                        Background="{StaticResource PurpleAccentBrush}">
                                    <TextBlock Text="May 23"
                                               Foreground="White"
                                               FontSize="13"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <!-- Name and description -->
                                <StackPanel Grid.Column="1"
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Employee Name"
                                               Foreground="{StaticResource PurpleAccentBrush}"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="Sick Leave"
                                               Foreground="#aaaaaa"
                                               FontSize="12" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                </Grid>

            </Grid>

            <!-- ─────────────────────────────────────────────────
                 Column 1 — Center Column (Calendar View)
                 ───────────────────────────────────────────────── -->
            <Grid Grid.Column="1" Margin="10,0,10,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />  <!-- Row 0: spacer matching greeting height -->
                    <RowDefinition Height="Auto" />  <!-- Row 1: calendar card -->
                </Grid.RowDefinitions>

                <!-- Row 0: Invisible spacer matching the greeting TextBlock height -->
                <TextBlock Grid.Row="0"
                           Text=" "
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,16"
                           Visibility="Hidden" />

                <!-- Row 1: Calendar card — stretches to match stats + attendance rows -->
                <Border Grid.Row="1"
                        Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />  <!-- Calendar header -->
                            <RowDefinition Height="Auto" />  <!-- Day-of-week labels -->
                            <RowDefinition Height="*"    />  <!-- Day cells -->
                            <RowDefinition Height="Auto" />  <!-- Live time -->
                        </Grid.RowDefinitions>

                        <!-- Calendar Header: month label (clickable for year picker) + prev/next buttons -->
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Clicking the month/year label opens the year picker -->
                            <Button x:Name="CalendarMonthLabel"
                                    Grid.Column="0"
                                    Style="{StaticResource PillButtonStyle}"
                                    Foreground="{StaticResource PurpleAccentBrush}"
                                    Background="Transparent"
                                    FontWeight="Bold"
                                    FontSize="18"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Padding="0"
                                    Click="CalendarMonthLabel_Click" />

                            <Button x:Name="PrevMonthButton"
                                    Grid.Column="1"
                                    Style="{StaticResource CircleButtonStyle}"
                                    Content="◀"
                                    Margin="0,0,4,0"
                                    Click="PrevMonth_Click" />

                            <Button x:Name="NextMonthButton"
                                    Grid.Column="2"
                                    Style="{StaticResource CircleButtonStyle}"
                                    Content="▶"
                                    Click="NextMonth_Click" />
                        </Grid>

                        <!-- Day-of-week header row -->
                        <UniformGrid Grid.Row="1"
                                     x:Name="DayHeaderRow"
                                     Columns="7"
                                     Margin="0,0,0,8">
                            <TextBlock Text="Sun" HorizontalAlignment="Center" Foreground="#aaaaaa" FontSize="13" />
                            <TextBlock Text="Mon" HorizontalAlignment="Center" Foreground="#aaaaaa" FontSize="13" />
                            <TextBlock Text="Tue" HorizontalAlignment="Center" Foreground="#aaaaaa" FontSize="13" />
                            <TextBlock Text="Wed" HorizontalAlignment="Center" Foreground="#aaaaaa" FontSize="13" />
                            <TextBlock Text="Thu" HorizontalAlignment="Center" Foreground="#aaaaaa" FontSize="13" />
                            <TextBlock Text="Fri" HorizontalAlignment="Center" Foreground="#aaaaaa" FontSize="13" />
                            <TextBlock Text="Sat" HorizontalAlignment="Center" Foreground="#aaaaaa" FontSize="13" />
                        </UniformGrid>

                        <!-- Calendar days grid — fills remaining height -->
                        <ItemsControl Grid.Row="2"
                                      x:Name="CalendarDaysControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="7" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Each day cell is a button so it is clickable -->
                                    <Button Margin="2"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Tag="{Binding Day}"
                                            Click="CalendarDay_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="DayBorder"
                                                                    Background="{TemplateBinding Background}"
                                                                    CornerRadius="20"
                                                                    Padding="2">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center" />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="DayBorder"
                                                                            Property="Background"
                                                                            Value="#44ffffff" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <!-- Today highlight -->
                                                    <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource PurpleAccentBrush}" />
                                                    </DataTrigger>
                                                    <!-- User-selected day -->
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="#9b7fe8" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="{Binding Day}"
                                                   FontSize="15"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   MinWidth="28"
                                                   MinHeight="28"
                                                   TextAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="White" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Day}" Value="0">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                        <!-- Today: dark text so it contrasts against the purple highlight -->
                                                        <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                            <Setter Property="Foreground" Value="#1a1a2e" />
                                                            <Setter Property="FontWeight" Value="ExtraBold" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Live clock — updates every second via DispatcherTimer -->
                        <TextBlock Grid.Row="3"
                                   x:Name="LiveClockLabel"
                                   Foreground="{StaticResource PurpleAccentBrush}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,14,0,0" />

                    </Grid>
                </Border>

            </Grid>

            <!-- ─────────────────────────────────────────────────
                 Column 2 — Right Column (Employee List)
                 ───────────────────────────────────────────────── -->
            <Border Grid.Column="2"
                    Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="12"
                    Margin="10,0,20,20"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />  <!-- Row 0: Header label -->
                        <RowDefinition Height="Auto" />  <!-- Row 1: List (auto-sized) -->
                        <RowDefinition Height="Auto" />  <!-- Row 2: Footer button -->
                    </Grid.RowDefinitions>

                    <!-- Row 0: Section header -->
                    <TextBlock Grid.Row="0"
                               Text="My Employees"
                               Foreground="{StaticResource PurpleAccentBrush}"
                               FontWeight="Bold"
                               FontSize="16"
                               Margin="0,0,0,12" />

                    <!-- Row 1: Scrollable employee list -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">
                        <ScrollViewer.Resources>
                            <!-- Reference CustomScrollbarStyle without redefining it inline -->
                            <Style TargetType="ScrollBar"
                                   BasedOn="{StaticResource CustomScrollbarStyle}" />
                        </ScrollViewer.Resources>

                        <ItemsControl x:Name="EmployeeListControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Padding="0"
                                            HorizontalContentAlignment="Stretch"
                                            Click="EmployeeListItem_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="ItemBorder"
                                                        Background="Transparent"
                                                        CornerRadius="8"
                                                        Padding="4,2">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemBorder"
                                                                Property="Background"
                                                                Value="#22ffffff" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,6,0,6">

                                            <!-- Circle avatar -->
                                            <Border Width="36"
                                                    Height="36"
                                                    CornerRadius="18"
                                                    Background="{StaticResource PurpleAccentBrush}"
                                                    Margin="0,0,12,0">
                                                <TextBlock Text="👤"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>

                                            <!-- Name and position -->
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="{StaticResource PurpleAccentBrush}"
                                                           FontWeight="Bold"
                                                           FontSize="13" />
                                                <TextBlock Text="{Binding Position}"
                                                           Foreground="#aaaaaa"
                                                           FontSize="11" />
                                            </StackPanel>

                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </ScrollViewer>

                    <!-- Row 2: Footer refresh button -->
                    <Button Grid.Row="2"
                            x:Name="EmployeeListRefreshButton"
                            Style="{StaticResource CircleButtonStyle}"
                            Content="↻"
                            HorizontalAlignment="Right"
                            Margin="0,8,0,0"
                            Click="EmployeeListRefresh_Click" />

                </Grid>
            </Border>

        </Grid>

        </ScrollViewer>

    </Grid>
</Window>
