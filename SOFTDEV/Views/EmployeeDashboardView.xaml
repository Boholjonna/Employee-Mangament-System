<UserControl x:Class="SOFTDEV.Views.EmployeeDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SOFTDEV.Views"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1400"
             Background="Transparent">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ScrollViewer.Resources>
            <Style TargetType="ScrollBar" BasedOn="{StaticResource CustomScrollbarStyle}" />
        </ScrollViewer.Resources>

        <Grid Margin="20,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- ─────────────────────────────────────────────────
                 Column 0 — Main Content
                 ───────────────────────────────────────────────── -->
            <StackPanel Grid.Column="0" Margin="0,0,10,0">

                <!-- Greeting -->
                <TextBlock x:Name="GreetingText"
                           Text="Hello Employee! 👋"
                           Foreground="{StaticResource PurpleAccentBrush}"
                           FontWeight="Bold"
                           FontSize="24"
                           Margin="0,0,0,20" />

                <!-- Summary Cards Row -->
                <UniformGrid Rows="1" Columns="3" Margin="0,0,0,20">

                    <!-- Tasks Completed Card -->
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            CornerRadius="12"
                            Margin="0,0,8,0"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="Tasks Completed"
                                       Foreground="#aaaaaa"
                                       FontSize="13"
                                       Margin="0,0,0,8" />
                            <TextBlock x:Name="TasksCompletedText"
                                       Text="85%"
                                       Foreground="{StaticResource PurpleAccentBrush}"
                                       FontWeight="Bold"
                                       FontSize="32" />
                            <TextBlock Text="This Month"
                                       Foreground="#888888"
                                       FontSize="11"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Attendance Rate Card -->
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            CornerRadius="12"
                            Margin="4,0,4,0"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="Attendance Rate"
                                       Foreground="#aaaaaa"
                                       FontSize="13"
                                       Margin="0,0,0,8" />
                            <TextBlock x:Name="AttendanceRateText"
                                       Text="96%"
                                       Foreground="{StaticResource PurpleAccentBrush}"
                                       FontWeight="Bold"
                                       FontSize="32" />
                            <TextBlock Text="This Month"
                                       Foreground="#888888"
                                       FontSize="11"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Performance Score Card -->
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            CornerRadius="12"
                            Margin="8,0,0,0"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="Performance Score"
                                       Foreground="#aaaaaa"
                                       FontSize="13"
                                       Margin="0,0,0,8" />
                            <TextBlock x:Name="PerformanceScoreText"
                                       Text="4.2/5.0"
                                       Foreground="{StaticResource PurpleAccentBrush}"
                                       FontWeight="Bold"
                                       FontSize="32" />
                            <TextBlock Text="Current Rating"
                                       Foreground="#888888"
                                       FontSize="11"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <!-- Charts Row -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Progress Chart -->
                    <Border Grid.Column="0"
                            Background="{StaticResource CardBackgroundBrush}"
                            CornerRadius="12"
                            Margin="0,0,8,0"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="Task Completion Progress"
                                       Foreground="{StaticResource PurpleAccentBrush}"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Margin="0,0,0,16" />
                            <Canvas x:Name="ProgressChartCanvas"
                                    Height="200"
                                    Background="Transparent" />
                            <TextBlock Text="Weekly Progress Trend"
                                       Foreground="#888888"
                                       FontSize="11"
                                       HorizontalAlignment="Center"
                                       Margin="0,24,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Attendance History Chart -->
                    <Border Grid.Column="1"
                            Background="{StaticResource CardBackgroundBrush}"
                            CornerRadius="12"
                            Margin="8,0,0,0"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="Attendance History"
                                       Foreground="{StaticResource PurpleAccentBrush}"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Margin="0,0,0,16" />
                            <Canvas x:Name="AttendanceChartCanvas"
                                    Height="200"
                                    Background="Transparent" />
                            <TextBlock Text="Last 7 Days"
                                       Foreground="#888888"
                                       FontSize="11"
                                       HorizontalAlignment="Center"
                                       Margin="0,24,0,0" />
                        </StackPanel>
                    </Border>

                </Grid>

                <!-- Recent Tasks Preview -->
                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="Recent Tasks"
                                   Foreground="{StaticResource PurpleAccentBrush}"
                                   FontWeight="Bold"
                                   FontSize="18"
                                   Margin="0,0,0,16" />
                        <TextBlock Text="You have 3 tasks in progress and 2 pending tasks."
                                   Foreground="#aaaaaa"
                                   FontSize="14"
                                   Margin="0,0,0,12" />
                            <Button x:Name="ViewAllTasksButton"
                                Content=" View All Tasks → "
                                Style="{StaticResource OutlinePillButtonStyle}"
                                Height="52"
                                HorizontalAlignment="Left"
                                Padding="100,12"
                                Margin="0,16,0,0"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Click="ViewAllTasks_Click" />
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- ─────────────────────────────────────────────────
                 Column 1 — Right Sidebar
                 ───────────────────────────────────────────────── -->
            <StackPanel Grid.Column="1" Margin="10,0,0,0">

                <!-- Notifications Panel -->
                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Padding="20"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Notifications"
                                   Foreground="{StaticResource PurpleAccentBrush}"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Margin="0,0,0,16" />

                        <ItemsControl x:Name="NotificationsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1a1a2e"
                                            CornerRadius="8"
                                            Padding="12"
                                            Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{StaticResource PurpleAccentBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Message}"
                                                       Foreground="#aaaaaa"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding Time}"
                                                       Foreground="#666666"
                                                       FontSize="10"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </Border>

                <!-- Quick Actions Panel -->
                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Padding="20"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Quick Actions"
                                   Foreground="{StaticResource PurpleAccentBrush}"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Margin="0,0,0,16" />

                        <Button x:Name="ClockInOutButton"
                                Content="🕐 Clock In/Out"
                                Style="{StaticResource PillButtonStyle}"
                                Height="44"
                                Margin="0,0,0,8" />

                        <Button x:Name="RequestLeaveButton"
                                Content="📅 Request Leave"
                                Style="{StaticResource OutlinePillButtonStyle}"
                                Height="44"
                                Margin="0,0,0,8" />

                        <Button x:Name="ViewPerformanceButton"
                                Content="📊 View Performance"
                                Style="{StaticResource OutlinePillButtonStyle}"
                                Height="44"
                                Margin="0,0,0,8" />

                        <Button x:Name="DownloadReportButton"
                            Content="📥 Download Report"
                                Style="{StaticResource OutlinePillButtonStyle}"
                                Height="44" />
                        

                    </StackPanel>
                </Border>

                <!-- Upcoming Events -->
                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="Upcoming Events"
                                   Foreground="{StaticResource PurpleAccentBrush}"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Margin="0,0,0,16" />

                        <ItemsControl x:Name="UpcomingEventsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1a1a2e"
                                            CornerRadius="8"
                                            Padding="12"
                                            Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding EventName}"
                                                       Foreground="White"
                                                       FontWeight="SemiBold"
                                                       FontSize="13" />
                                            <TextBlock Text="{Binding EventDate}"
                                                       Foreground="{StaticResource PurpleAccentBrush}"
                                                       FontSize="11"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </Border>

            </StackPanel>

        </Grid>

    </ScrollViewer>
</UserControl>
