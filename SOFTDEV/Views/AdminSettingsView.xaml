<UserControl x:Class="SOFTDEV.Views.AdminSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SOFTDEV.Views"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1400"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ScrollViewer.Resources>
            <Style TargetType="ScrollBar" BasedOn="{StaticResource CustomScrollbarStyle}" />
        </ScrollViewer.Resources>

        <StackPanel Margin="20">

            <!-- Page title -->
            <TextBlock Text="Settings"
                       Foreground="{StaticResource PurpleAccentBrush}"
                       FontWeight="Bold" FontSize="28"
                       Margin="0,0,0,24" />

            <!-- ── Row 1: Account & Security  |  System Settings ── -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Account & Security -->
                <Border Grid.Column="0"
                        Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="14" Margin="0,0,8,0" Padding="28">
                    <StackPanel>
                        <TextBlock Text="Account &amp; Security"
                                   Foreground="{StaticResource PurpleAccentBrush}"
                                   FontWeight="Bold" FontSize="17" Margin="0,0,0,18" />

                        <!-- Change Password -->
                        <TextBlock Text="Change Password"
                                   Foreground="White" FontWeight="SemiBold" FontSize="14"
                                   Margin="0,0,0,10" />
                        <TextBlock Text="Current Password" Foreground="#aaaaaa" FontSize="12" Margin="0,0,0,6" />
                        <PasswordBox x:Name="CurrentPasswordBox"
                                     Style="{StaticResource RoundedPasswordBoxStyle}"
                                     Margin="0,0,0,12" />
                        <TextBlock Text="New Password" Foreground="#aaaaaa" FontSize="12" Margin="0,0,0,6" />
                        <PasswordBox x:Name="NewPasswordBox"
                                     Style="{StaticResource RoundedPasswordBoxStyle}"
                                     Margin="0,0,0,12" />
                        <TextBlock Text="Confirm New Password" Foreground="#aaaaaa" FontSize="12" Margin="0,0,0,6" />
                        <PasswordBox x:Name="ConfirmPasswordBox"
                                     Style="{StaticResource RoundedPasswordBoxStyle}"
                                     Margin="0,0,0,16" />
                        <Button Content="Update Password"
                                Style="{StaticResource PillButtonStyle}"
                                Height="40" HorizontalAlignment="Left" Padding="28,0"
                                Margin="0,0,0,24"
                                Click="UpdatePassword_Click" />

                        <!-- Two-Factor Authentication -->
                        <TextBlock Text="Two Factor Authentication"
                                   Foreground="White" FontWeight="SemiBold" FontSize="14"
                                   Margin="0,0,0,10" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Status:" Foreground="#aaaaaa" FontSize="13"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock x:Name="TwoFAStatusLabel" Text="Disabled"
                                       Foreground="#e8c84a" FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <Button x:Name="TwoFAToggleButton"
                                Content="Enable 2FA"
                                Style="{StaticResource PillButtonStyle}"
                                Height="40" HorizontalAlignment="Left" Padding="28,0"
                                Margin="0,0,0,24"
                                Click="TwoFAToggle_Click" />

                        <!-- Security Preference -->
                        <TextBlock Text="Security Preference"
                                   Foreground="White" FontWeight="SemiBold" FontSize="14"
                                   Margin="0,0,0,12" />
                        <CheckBox x:Name="AutoLogoutCheck"
                                  Content="Auto logout after 30 minutes of inactivity"
                                  Style="{StaticResource RoleCheckBoxStyle}"
                                  IsChecked="True" Margin="0,0,0,10" />
                        <CheckBox x:Name="LoginAlertCheck"
                                  Content="Send email alert on new login"
                                  Style="{StaticResource RoleCheckBoxStyle}"
                                  IsChecked="True" Margin="0,0,0,10" />
                        <CheckBox x:Name="StrongPasswordCheck"
                                  Content="Require strong passwords for all users"
                                  Style="{StaticResource RoleCheckBoxStyle}"
                                  IsChecked="False" Margin="0,0,0,16" />
                        <Button Content="Save Security Settings"
                                Style="{StaticResource PillButtonStyle}"
                                Height="40" HorizontalAlignment="Left" Padding="28,0"
                                Click="SaveSecurity_Click" />
                    </StackPanel>
                </Border>

                <!-- System Settings -->
                <Border Grid.Column="1"
                        Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="14" Margin="8,0,0,0" Padding="28">
                    <StackPanel>
                        <TextBlock Text="System Settings"
                                   Foreground="{StaticResource PurpleAccentBrush}"
                                   FontWeight="Bold" FontSize="17" Margin="0,0,0,18" />

                        <!-- Company Information -->
                        <TextBlock Text="Company Information"
                                   Foreground="White" FontWeight="SemiBold" FontSize="14"
                                   Margin="0,0,0,10" />
                        <TextBlock Text="Company Name" Foreground="#aaaaaa" FontSize="12" Margin="0,0,0,6" />
                        <TextBox x:Name="CompanyNameBox" Text="Nexis Corp"
                                 Style="{StaticResource RoundedTextBoxStyle}" Margin="0,0,0,12" />
                        <TextBlock Text="Company Email" Foreground="#aaaaaa" FontSize="12" Margin="0,0,0,6" />
                        <TextBox x:Name="CompanyEmailBox" Text="admin@nexiscorp.com"
                                 Style="{StaticResource RoundedTextBoxStyle}" Margin="0,0,0,12" />
                        <TextBlock Text="Company Address" Foreground="#aaaaaa" FontSize="12" Margin="0,0,0,6" />
                        <TextBox x:Name="CompanyAddressBox" Text="123 Business Ave, City"
                                 Style="{StaticResource RoundedTextBoxStyle}" Margin="0,0,0,16" />
                        <Button Content="Save Company Info"
                                Style="{StaticResource PillButtonStyle}"
                                Height="40" HorizontalAlignment="Left" Padding="28,0"
                                Margin="0,0,0,24"
                                Click="SaveCompanyInfo_Click" />

                        <!-- Timezone Management -->
                        <TextBlock Text="Timezone Management"
                                   Foreground="White" FontWeight="SemiBold" FontSize="14"
                                   Margin="0,0,0,10" />
                        <TextBlock Text="Select Timezone" Foreground="#aaaaaa" FontSize="12" Margin="0,0,0,6" />
                        <ComboBox x:Name="TimezoneCombo"
                                  Style="{StaticResource RoundedComboBoxStyle}"
                                  Margin="0,0,0,16">
                            <ComboBoxItem Content="(UTC+08:00) Manila" IsSelected="True" />
                            <ComboBoxItem Content="(UTC+00:00) UTC" />
                            <ComboBoxItem Content="(UTC-05:00) Eastern Time" />
                            <ComboBoxItem Content="(UTC-08:00) Pacific Time" />
                            <ComboBoxItem Content="(UTC+09:00) Tokyo" />
                        </ComboBox>
                        <Button Content="Save Timezone"
                                Style="{StaticResource PillButtonStyle}"
                                Height="40" HorizontalAlignment="Left" Padding="28,0"
                                Margin="0,0,0,24"
                                Click="SaveTimezone_Click" />

                        <!-- Edit Working Hours -->
                        <TextBlock Text="Edit Working Hours"
                                   Foreground="White" FontWeight="SemiBold" FontSize="14"
                                   Margin="0,0,0,10" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Start Time" Foreground="#aaaaaa" FontSize="12" Margin="0,0,0,6" />
                                <TextBox x:Name="WorkStartBox" Text="08:00 AM"
                                         Style="{StaticResource RoundedTextBoxStyle}" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="–" Foreground="White" FontSize="16"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,16,0,0" />
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="End Time" Foreground="#aaaaaa" FontSize="12" Margin="0,0,0,6" />
                                <TextBox x:Name="WorkEndBox" Text="05:00 PM"
                                         Style="{StaticResource RoundedTextBoxStyle}" />
                            </StackPanel>
                        </Grid>
                        <Button Content="Save Working Hours"
                                Style="{StaticResource PillButtonStyle}"
                                Height="40" HorizontalAlignment="Left" Padding="28,0"
                                Margin="0,0,0,24"
                                Click="SaveWorkingHours_Click" />

                        <!-- Holiday Management -->
                        <TextBlock Text="Holiday Management"
                                   Foreground="White" FontWeight="SemiBold" FontSize="14"
                                   Margin="0,0,0,10" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="HolidayNameBox"
                                     Style="{StaticResource RoundedTextBoxStyle}"
                                     Tag="Holiday name (e.g. Christmas)" />
                            <Button Grid.Column="2"
                                    Content="+ Add"
                                    Style="{StaticResource PillButtonStyle}"
                                    Height="40" Padding="20,0"
                                    Click="AddHoliday_Click" />
                        </Grid>
                        <ListBox x:Name="HolidayListBox"
                                 Background="#1e1e2a"
                                 BorderBrush="#7b61ff" BorderThickness="1"
                                 Foreground="White" FontSize="13"
                                 MinHeight="80" MaxHeight="140"
                                 Margin="0,0,0,8" />
                        <Button Content="Remove Selected"
                                Style="{StaticResource OutlinePillButtonStyle}"
                                Height="36" HorizontalAlignment="Left" Padding="20,0"
                                Click="RemoveHoliday_Click" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Row 2: Notification Settings  |  User Management ── -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Notification Settings -->
                <Border Grid.Column="0"
                        Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="14" Margin="0,0,8,0" Padding="28">
                    <StackPanel>
                        <TextBlock Text="Notification Settings"
                                   Foreground="{StaticResource PurpleAccentBrush}"
                                   FontWeight="Bold" FontSize="17" Margin="0,0,0,18" />

                        <CheckBox Content="Email notifications for leave requests"
                                  Style="{StaticResource RoleCheckBoxStyle}"
                                  IsChecked="True" Margin="0,0,0,12" />
                        <CheckBox Content="Email notifications for new employee registration"
                                  Style="{StaticResource RoleCheckBoxStyle}"
                                  IsChecked="True" Margin="0,0,0,12" />
                        <CheckBox Content="Email notifications for task assignments"
                                  Style="{StaticResource RoleCheckBoxStyle}"
                                  IsChecked="True" Margin="0,0,0,12" />
                        <CheckBox Content="System alerts for attendance anomalies"
                                  Style="{StaticResource RoleCheckBoxStyle}"
                                  IsChecked="False" Margin="0,0,0,12" />
                        <CheckBox Content="Weekly summary report via email"
                                  Style="{StaticResource RoleCheckBoxStyle}"
                                  IsChecked="True" Margin="0,0,0,20" />

                        <Button Content="Save Notification Settings"
                                Style="{StaticResource PillButtonStyle}"
                                Height="40" HorizontalAlignment="Left" Padding="28,0"
                                Click="SaveNotifications_Click" />
                    </StackPanel>
                </Border>

                <!-- User Management -->
                <Border Grid.Column="1"
                        Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="14" Margin="8,0,0,0" Padding="28">
                    <StackPanel>
                        <TextBlock Text="User Management"
                                   Foreground="{StaticResource PurpleAccentBrush}"
                                   FontWeight="Bold" FontSize="17" Margin="0,0,0,18" />

                        <TextBlock Text="Default Role for New Users"
                                   Foreground="White" FontWeight="SemiBold" FontSize="14"
                                   Margin="0,0,0,10" />
                        <ComboBox x:Name="DefaultRoleCombo"
                                  Style="{StaticResource RoundedComboBoxStyle}"
                                  Margin="0,0,0,20">
                            <ComboBoxItem Content="Employee" IsSelected="True" />
                            <ComboBoxItem Content="Manager" />
                            <ComboBoxItem Content="Admin" />
                        </ComboBox>

                        <TextBlock Text="Account Policies"
                                   Foreground="White" FontWeight="SemiBold" FontSize="14"
                                   Margin="0,0,0,12" />
                        <CheckBox Content="Require email verification on signup"
                                  Style="{StaticResource RoleCheckBoxStyle}"
                                  IsChecked="True" Margin="0,0,0,10" />
                        <CheckBox Content="Allow managers to create employee accounts"
                                  Style="{StaticResource RoleCheckBoxStyle}"
                                  IsChecked="True" Margin="0,0,0,10" />
                        <CheckBox Content="Lock account after 5 failed login attempts"
                                  Style="{StaticResource RoleCheckBoxStyle}"
                                  IsChecked="True" Margin="0,0,0,20" />

                        <Button Content="Save User Policies"
                                Style="{StaticResource PillButtonStyle}"
                                Height="40" HorizontalAlignment="Left" Padding="28,0"
                                Click="SaveUserPolicies_Click" />
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
