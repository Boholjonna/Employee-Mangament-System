<UserControl x:Class="SOFTDEV.Views.EmployeeTasksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SOFTDEV.Views"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1400"
             Background="Transparent">
    
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="My Tasks"
                       Foreground="{StaticResource PurpleAccentBrush}"
                       FontWeight="Bold"
                       FontSize="28"
                       Margin="0,0,0,20" />

            <!-- Task Stats -->
            <UniformGrid Rows="1" Columns="4" Margin="0,0,0,24">
                
                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Margin="0,0,8,0"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="Total Tasks"
                                   Foreground="#aaaaaa"
                                   FontSize="12" />
                        <TextBlock x:Name="TotalTasksCount"
                                   Text="0"
                                   Foreground="{StaticResource PurpleAccentBrush}"
                                   FontWeight="Bold"
                                   FontSize="32"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Margin="4,0,4,0"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="In Progress"
                                   Foreground="#aaaaaa"
                                   FontSize="12" />
                        <TextBlock x:Name="InProgressCount"
                                   Text="0"
                                   Foreground="#ff9800"
                                   FontWeight="Bold"
                                   FontSize="32"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Margin="4,0,4,0"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="Completed"
                                   Foreground="#aaaaaa"
                                   FontSize="12" />
                        <TextBlock x:Name="CompletedCount"
                                   Text="0"
                                   Foreground="#4caf50"
                                   FontWeight="Bold"
                                   FontSize="32"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Margin="8,0,0,0"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="Not Started"
                                   Foreground="#aaaaaa"
                                   FontSize="12" />
                        <TextBlock x:Name="NotStartedCount"
                                   Text="0"
                                   Foreground="#f44336"
                                   FontWeight="Bold"
                                   FontSize="32"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- Task List Section -->
            <Border Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="12"
                    Padding="24">
                <StackPanel>
                    <Grid Margin="0,0,0,20">
                        <TextBlock Text="Task List"
                                   Foreground="{StaticResource PurpleAccentBrush}"
                                   FontWeight="Bold"
                                   FontSize="20"
                                   VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <ComboBox x:Name="TaskFilterComboBox"
                                      Width="140"
                                      Height="36"
                                      Margin="0,0,12,0"
                                      SelectionChanged="TaskFilter_Changed">
                                <ComboBoxItem Content="All Tasks" IsSelected="True" />
                                <ComboBoxItem Content="In Progress" />
                                <ComboBoxItem Content="Completed" />
                                <ComboBoxItem Content="Not Started" />
                            </ComboBox>
                            <Button Content="+ New Task"
                                    Style="{StaticResource PillButtonStyle}"
                                    Height="36"
                                    Padding="20,0"
                                    Click="AddTask_Click" />
                        </StackPanel>
                    </Grid>

                    <ScrollViewer MaxHeight="600" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <ItemsControl x:Name="TaskListControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1a1a2e"
                                                CornerRadius="10"
                                                Padding="20"
                                                Margin="0,0,0,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsCompleted}"
                                                          Style="{StaticResource RoleCheckBoxStyle}"
                                                          Margin="0,0,16,0"
                                                          VerticalAlignment="Center" />

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="White"
                                                               FontWeight="SemiBold"
                                                               FontSize="16" />
                                                    <TextBlock Text="{Binding Description}"
                                                               Foreground="#aaaaaa"
                                                               FontSize="13"
                                                               Margin="0,6,0,0"
                                                               TextWrapping="Wrap" />
                                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                                        <Border Background="{Binding StatusBrush}"
                                                                CornerRadius="6"
                                                                Padding="12,6"
                                                                Margin="0,0,12,0">
                                                            <TextBlock Text="{Binding Status}"
                                                                       Foreground="White"
                                                                       FontSize="11"
                                                                       FontWeight="Bold" />
                                                        </Border>
                                                        <TextBlock Text="{Binding DueDate}"
                                                                   Foreground="#888888"
                                                                   FontSize="12"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </StackPanel>

                                                <Button Grid.Column="2"
                                                        Content="Update"
                                                        Style="{StaticResource OutlinePillButtonStyle}"
                                                        Height="36"
                                                        Padding="20,0"
                                                        VerticalAlignment="Center"
                                                        Click="UpdateTask_Click" />

                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Empty state -->
                            <TextBlock x:Name="NoTasksMessage"
                                       Text="No task available"
                                       Foreground="#888888"
                                       FontSize="16"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0,32,0,0"
                                       Visibility="Collapsed" />
                        </Grid>
                    </ScrollViewer>

                </StackPanel>
            </Border>

        </StackPanel>
    </Grid>
</UserControl>
