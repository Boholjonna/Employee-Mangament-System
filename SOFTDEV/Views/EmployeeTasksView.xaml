<UserControl x:Class="SOFTDEV.Views.EmployeeTasksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SOFTDEV.Views"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1400"
             Background="Transparent">
    
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="My Tasks"
                       Foreground="{StaticResource PurpleAccentBrush}"
                       FontWeight="Bold"
                       FontSize="28"
                       Margin="0,0,0,20" />

            <!-- Task Stats -->
            <UniformGrid Rows="1" Columns="4" Margin="0,0,0,24">
                
                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Margin="0,0,8,0"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="Total Tasks"
                                   Foreground="#aaaaaa"
                                   FontSize="12" />
                        <TextBlock x:Name="TotalTasksCount"
                                   Text="0"
                                   Foreground="{StaticResource PurpleAccentBrush}"
                                   FontWeight="Bold"
                                   FontSize="32"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Margin="4,0,4,0"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="In Progress"
                                   Foreground="#aaaaaa"
                                   FontSize="12" />
                        <TextBlock x:Name="InProgressCount"
                                   Text="0"
                                   Foreground="#ff9800"
                                   FontWeight="Bold"
                                   FontSize="32"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Margin="4,0,4,0"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="Completed"
                                   Foreground="#aaaaaa"
                                   FontSize="12" />
                        <TextBlock x:Name="CompletedCount"
                                   Text="0"
                                   Foreground="#4caf50"
                                   FontWeight="Bold"
                                   FontSize="32"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Margin="8,0,0,0"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="Not Started"
                                   Foreground="#aaaaaa"
                                   FontSize="12" />
                        <TextBlock x:Name="NotStartedCount"
                                   Text="0"
                                   Foreground="#f44336"
                                   FontWeight="Bold"
                                   FontSize="32"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- Task List Section -->
            <Border Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="12"
                    Padding="24">
                <StackPanel>
                    <Grid Margin="0,0,0,20">
                        <TextBlock Text="Task List"
                                   Foreground="{StaticResource PurpleAccentBrush}"
                                   FontWeight="Bold"
                                   FontSize="20"
                                   VerticalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <ComboBox x:Name="TaskFilterComboBox"
                                      Width="160"
                                      Style="{StaticResource RoundedComboBoxStyle}"
                                      SelectionChanged="TaskFilter_Changed">
                                    <ComboBoxItem Content="All Tasks" IsSelected="True" />
                                    <ComboBoxItem Content="In Progress" />
                                    <ComboBoxItem Content="Completed" />
                                    <ComboBoxItem Content="Not Started" />
                                </ComboBox>
                                <Button x:Name="NewTaskToggleButton"
                                    Content="  + Add New Task  "
                                    Style="{StaticResource PillButtonStyle}"
                                    Height="44"
                                    MinWidth="260"
                                    Padding="48,0"
                                    Margin="20,0,0,0"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Click="NewTaskToggleButton_Click" />
                        </StackPanel>
                    </Grid>

                    <!-- Add Task Panel (collapsible) -->
                    <StackPanel x:Name="AddTaskPanel" Visibility="Collapsed" Margin="0,0,0,16">
                        <TextBlock Text="New Task" Foreground="White" FontWeight="Bold" FontSize="16" Margin="0,0,0,12" />
                        <StackPanel Orientation="Vertical" Margin="0,0,0,12">
                            <TextBlock Text="Task Title"
                                       Foreground="#aaaaaa"
                                       FontSize="11"
                                       Margin="0,0,0,4" />
                            <TextBox x:Name="NewTaskTitle"
                                     Style="{StaticResource RoundedTextBoxStyle}"
                                     Margin="0,0,0,12" />
                            
                            <TextBlock Text="Description"
                                       Foreground="#aaaaaa"
                                       FontSize="11"
                                       Margin="0,0,0,4" />
                            <TextBox x:Name="NewTaskDescription"
                                     Style="{StaticResource RoundedTextBoxStyle}"
                                     Height="80"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Margin="0,0,0,12" />
                            
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Due Date"
                                               Foreground="#aaaaaa"
                                               FontSize="11"
                                               Margin="0,0,0,4" />
                                    <DatePicker x:Name="NewTaskDueDate"
                                                Style="{StaticResource RoundedDatePickerStyle}"
                                                Width="180" />
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Estimated Hours"
                                               Foreground="#aaaaaa"
                                               FontSize="11"
                                               Margin="0,0,0,4" />
                                    <TextBox x:Name="NewTaskEstimatedHours"
                                             Style="{StaticResource RoundedTextBoxStyle}"
                                             Width="120" />
                                </StackPanel>
                            </Grid>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button Content="Save"
                                        Style="{StaticResource PillButtonStyle}"
                                        Click="SaveNewTask_Click"
                                        Height="40"
                                        MinWidth="150"
                                        Padding="34,0"
                                        Margin="0,0,12,0"
                                        FontSize="14"
                                        FontWeight="SemiBold" />
                                <Button Content="Cancel"
                                        Style="{StaticResource OutlinePillButtonStyle}"
                                        Click="CancelNewTask_Click"
                                        Height="40"
                                        MinWidth="150"
                                        Padding="34,0"
                                        FontSize="14"
                                        FontWeight="SemiBold" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <ScrollViewer MaxHeight="600" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <ItemsControl x:Name="TaskListControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1a1a2e"
                                                CornerRadius="10"
                                                Padding="20"
                                                Margin="0,0,0,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsCompleted}"
                                                          Style="{StaticResource RoleCheckBoxStyle}"
                                                          Margin="0,0,16,0"
                                                          VerticalAlignment="Center"
                                                          Checked="TaskCompleted_Checked"
                                                          Unchecked="TaskCompleted_Unchecked" />

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="White"
                                                               FontWeight="SemiBold"
                                                               FontSize="16" />
                                                    <TextBlock Text="{Binding Description}"
                                                               Foreground="#aaaaaa"
                                                               FontSize="13"
                                                               Margin="0,6,0,0"
                                                               TextWrapping="Wrap" />
                                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                                        <Border Background="{Binding StatusBrush}"
                                                                CornerRadius="6"
                                                                Padding="12,6"
                                                                Margin="0,0,12,0">
                                                            <TextBlock Text="{Binding Status}"
                                                                       Foreground="White"
                                                                       FontSize="11"
                                                                       FontWeight="Bold" />
                                                        </Border>
                                                        <TextBlock Text="{Binding DueDate}"
                                                                   Foreground="#888888"
                                                                   FontSize="12"
                                                                   VerticalAlignment="Center" />
                                                        <TextBlock Text=", " Foreground="#888888" FontSize="12" />
                                                        <TextBlock Text="Est: {Binding EstimatedHours}h"
                                                                   Foreground="#888888"
                                                                   FontSize="12"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </StackPanel>

                                                <Button Grid.Column="2"
                                                        Content="Update"
                                                        Style="{StaticResource OutlinePillButtonStyle}"
                                                        Height="36"
                                                        Padding="20,0"
                                                        VerticalAlignment="Center"
                                                        Click="UpdateTask_Click" />

                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Empty state -->
                            <TextBlock x:Name="NoTasksMessage"
                                       Text="No task available"
                                       Foreground="#888888"
                                       FontSize="16"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0,32,0,0"
                                       Visibility="Collapsed" />
                        </Grid>
                    </ScrollViewer>

                </StackPanel>
            </Border>

        </StackPanel>
    </Grid>
</UserControl>
