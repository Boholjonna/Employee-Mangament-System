<UserControl x:Class="SOFTDEV.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:SOFTDEV.Views"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="{StaticResource DarkBackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ScrollViewer.Resources>
            <Style TargetType="ScrollBar" BasedOn="{StaticResource CustomScrollbarStyle}" />
        </ScrollViewer.Resources>

        <Grid Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- Main Content -->
            <StackPanel Grid.Column="0" Margin="0,0,10,0">

                <TextBlock Text="Reports"
                           Foreground="{StaticResource PurpleAccentBrush}"
                           FontWeight="Bold"
                           FontSize="28"
                           Margin="0,0,0,20" />

                <!-- Generate Report Section -->
                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Padding="24"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Generate New Report"
                                   Foreground="{StaticResource PurpleAccentBrush}"
                                   FontWeight="Bold"
                                   FontSize="18"
                                   Margin="0,0,0,20" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Report Type"
                                           Foreground="#aaaaaa"
                                           FontSize="11"
                                           Margin="0,0,0,4" />
                                <ComboBox x:Name="ReportTypeComboBox"
                                          Height="40"
                                          Margin="0,0,0,16">
                                    <ComboBoxItem Content="Task Summary" IsSelected="True" />
                                    <ComboBoxItem Content="Attendance Report" />
                                    <ComboBoxItem Content="Performance Report" />
                                    <ComboBoxItem Content="Complete Report" />
                                </ComboBox>

                                <TextBlock Text="Date Range"
                                           Foreground="#aaaaaa"
                                           FontSize="11"
                                           Margin="0,0,0,4" />
                                <ComboBox x:Name="DateRangeComboBox"
                                          Height="40"
                                          Margin="0,0,0,16">
                                    <ComboBoxItem Content="This Week" />
                                    <ComboBoxItem Content="This Month" IsSelected="True" />
                                    <ComboBoxItem Content="Last Month" />
                                    <ComboBoxItem Content="This Quarter" />
                                    <ComboBoxItem Content="This Year" />
                                    <ComboBoxItem Content="Custom Range" />
                                </ComboBox>

                                <TextBlock Text="Export Format"
                                           Foreground="#aaaaaa"
                                           FontSize="11"
                                           Margin="0,0,0,4" />
                                <ComboBox x:Name="ExportFormatComboBox"
                                          Height="40">
                                    <ComboBoxItem Content="PDF" IsSelected="True" />
                                    <ComboBoxItem Content="Excel (XLSX)" />
                                    <ComboBoxItem Content="CSV" />
                                    <ComboBoxItem Content="JSON" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="Custom Date Range"
                                           Foreground="#aaaaaa"
                                           FontSize="11"
                                           Margin="0,0,0,4" />
                                <DatePicker x:Name="StartDatePicker"
                                            Height="40"
                                            Margin="0,0,0,12" />

                                <TextBlock Text="End Date"
                                           Foreground="#aaaaaa"
                                           FontSize="11"
                                           Margin="0,0,0,4" />
                                <DatePicker x:Name="EndDatePicker"
                                            Height="40"
                                            Margin="0,0,0,16" />

                                <CheckBox Content="Include Charts"
                                          Style="{StaticResource RoleCheckBoxStyle}"
                                          IsChecked="True"
                                          Margin="0,0,0,8" />
                                <CheckBox Content="Include Summary"
                                          Style="{StaticResource RoleCheckBoxStyle}"
                                          IsChecked="True"
                                          Margin="0,0,0,8" />
                                <CheckBox Content="Include Details"
                                          Style="{StaticResource RoleCheckBoxStyle}"
                                          IsChecked="True" />
                            </StackPanel>

                        </Grid>

                        <Grid Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Content="Preview Report"
                                    Style="{StaticResource OutlinePillButtonStyle}"
                                    Height="48"
                                    Margin="0,0,12,0"
                                    Click="PreviewReport_Click" />

                            <Button Grid.Column="1"
                                    Content="📥 Generate &amp; Download"
                                    Style="{StaticResource PillButtonStyle}"
                                    Height="48"
                                    Padding="32,0"
                                    Click="GenerateReport_Click" />
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- Recent Reports -->
                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="Recent Reports"
                                   Foreground="{StaticResource PurpleAccentBrush}"
                                   FontWeight="Bold"
                                   FontSize="18"
                                   Margin="0,0,0,16" />

                        <ItemsControl x:Name="RecentReportsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1a1a2e"
                                            CornerRadius="8"
                                            Padding="16"
                                            Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Icon}"
                                                       FontSize="24"
                                                       Margin="0,0,16,0"
                                                       VerticalAlignment="Center" />

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="White"
                                                           FontWeight="SemiBold"
                                                           FontSize="14" />
                                                <TextBlock Text="{Binding Details}"
                                                           Foreground="#aaaaaa"
                                                           FontSize="11"
                                                           Margin="0,4,0,0" />
                                            </StackPanel>

                                            <Button Grid.Column="2"
                                                    Content="Download"
                                                    Style="{StaticResource OutlinePillButtonStyle}"
                                                    Height="32"
                                                    Padding="16,0"
                                                    VerticalAlignment="Center"
                                                    Click="DownloadReport_Click" />

                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- Sidebar -->
            <StackPanel Grid.Column="1" Margin="10,0,0,0">

                <!-- Quick Reports -->
                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Padding="20"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Quick Reports"
                                   Foreground="{StaticResource PurpleAccentBrush}"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Margin="0,0,0,16" />

                        <Button Content="📊 This Week Summary"
                                Style="{StaticResource PillButtonStyle}"
                                Height="44"
                                Margin="0,0,0,8"
                                Click="QuickReport_Click" />

                        <Button Content="📅 Monthly Report"
                                Style="{StaticResource OutlinePillButtonStyle}"
                                Height="44"
                                Margin="0,0,0,8"
                                Click="QuickReport_Click" />

                        <Button Content="⏰ Attendance Log"
                                Style="{StaticResource OutlinePillButtonStyle}"
                                Height="44"
                                Margin="0,0,0,8"
                                Click="QuickReport_Click" />

                        <Button Content="✅ Task Completion"
                                Style="{StaticResource OutlinePillButtonStyle}"
                                Height="44"
                                Click="QuickReport_Click" />

                    </StackPanel>
                </Border>

                <!-- Report Statistics -->
                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Padding="20"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Report Statistics"
                                   Foreground="{StaticResource PurpleAccentBrush}"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Margin="0,0,0,16" />

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Total Reports Generated"
                                       Foreground="#aaaaaa"
                                       FontSize="11" />
                            <TextBlock Text="47"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="24"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="This Month"
                                       Foreground="#aaaaaa"
                                       FontSize="11" />
                            <TextBlock Text="8 reports"
                                       Foreground="{StaticResource PurpleAccentBrush}"
                                       FontWeight="Bold"
                                       FontSize="18"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Most Generated"
                                       Foreground="#aaaaaa"
                                       FontSize="11" />
                            <TextBlock Text="Task Summary"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                    </StackPanel>
                </Border>

                <!-- Help -->
                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="💡 Tips"
                                   Foreground="{StaticResource PurpleAccentBrush}"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Margin="0,0,0,12" />

                        <TextBlock Text="• Use custom date ranges for specific periods"
                                   Foreground="#aaaaaa"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />

                        <TextBlock Text="• Include charts for visual insights"
                                   Foreground="#aaaaaa"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />

                        <TextBlock Text="• Export to Excel for further analysis"
                                   Foreground="#aaaaaa"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />

                        <TextBlock Text="• Preview before downloading"
                                   Foreground="#aaaaaa"
                                   FontSize="12"
                                   TextWrapping="Wrap" />

                    </StackPanel>
                </Border>

            </StackPanel>

        </Grid>

    </ScrollViewer>
</UserControl>
