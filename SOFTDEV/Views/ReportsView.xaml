<UserControl x:Class="SOFTDEV.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="{StaticResource DarkBackgroundBrush}">

    <UserControl.Resources>

        <!-- Header cell style -->
        <Style x:Key="HeaderCellStyle" TargetType="Border">
            <Setter Property="Background"   Value="#c4b5fd" />
            <Setter Property="BorderBrush"  Value="#1a1a2e" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding"      Value="10,10" />
            <Setter Property="MinHeight"    Value="48" />
        </Style>

        <!-- Header text style -->
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground"       Value="#1a1a2e" />
            <Setter Property="FontWeight"       Value="Bold" />
            <Setter Property="FontSize"         Value="11" />
            <Setter Property="TextAlignment"    Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment"   Value="Center" />
            <Setter Property="TextWrapping"     Value="Wrap" />
        </Style>

        <!-- Data cell style -->
        <Style x:Key="DataCellStyle" TargetType="Border">
            <Setter Property="Background"      Value="#ddd6fe" />
            <Setter Property="BorderBrush"     Value="#1a1a2e" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding"         Value="10,8" />
            <Setter Property="MinHeight"       Value="44" />
        </Style>

        <!-- Data text style -->
        <Style x:Key="DataTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground"          Value="#1a1a2e" />
            <Setter Property="FontSize"            Value="13" />
            <Setter Property="TextAlignment"       Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment"   Value="Center" />
            <Setter Property="TextWrapping"        Value="Wrap" />
        </Style>

        <!-- Status badge style -->
        <Style x:Key="StatusBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius"        Value="12" />
            <Setter Property="Padding"             Value="12,4" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <ScrollViewer.Resources>
            <Style TargetType="ScrollBar" BasedOn="{StaticResource CustomScrollbarStyle}" />
        </ScrollViewer.Resources>

        <StackPanel Margin="24,20,24,24">

            <!-- Greeting -->
            <TextBlock x:Name="GreetingLabel"
                       Text="Hello Admin Name! 👋"
                       Foreground="{StaticResource PurpleAccentBrush}"
                       FontWeight="Bold"
                       FontSize="20"
                       Margin="0,0,0,20" />

            <!-- Employee Performance Card -->
            <Border Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="14"
                    Padding="20">
                <StackPanel>

                    <!-- Card title row -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Employee Performance"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="18"
                                   VerticalAlignment="Center" />

                        <!-- Refresh button -->
                        <Button Grid.Column="1"
                                x:Name="RefreshButton"
                                Style="{StaticResource CircleButtonStyle}"
                                Content="↻"
                                ToolTip="Refresh data"
                                Click="RefreshButton_Click" />
                    </Grid>

                    <!-- ── Table ── -->
                    <Border BorderBrush="#1a1a2e"
                            BorderThickness="1,1,0,0"
                            CornerRadius="8"
                            ClipToBounds="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <!-- Header row -->
                                <RowDefinition Height="Auto" />
                                <!-- Data rows via ItemsControl -->
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- ── Header Row ── -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="1.4*" />
                                    <ColumnDefinition Width="1.4*" />
                                    <ColumnDefinition Width="1.4*" />
                                    <ColumnDefinition Width="1.6*" />
                                    <ColumnDefinition Width="1.4*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource HeaderCellStyle}">
                                    <TextBlock Text="EMPLOYEE" Style="{StaticResource HeaderTextStyle}" />
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource HeaderCellStyle}">
                                    <TextBlock Text="DEPARTMENT" Style="{StaticResource HeaderTextStyle}" />
                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource HeaderCellStyle}">
                                    <TextBlock Text="TASK" Style="{StaticResource HeaderTextStyle}" />
                                </Border>
                                <Border Grid.Column="3" Style="{StaticResource HeaderCellStyle}">
                                    <TextBlock Text="ATTENDANCE %" Style="{StaticResource HeaderTextStyle}" />
                                </Border>
                                <Border Grid.Column="4" Style="{StaticResource HeaderCellStyle}">
                                    <TextBlock Text="PERFORMANCE SCORE" Style="{StaticResource HeaderTextStyle}" />
                                </Border>
                                <Border Grid.Column="5" Style="{StaticResource HeaderCellStyle}">
                                    <TextBlock Text="STATUS" Style="{StaticResource HeaderTextStyle}" />
                                </Border>
                            </Grid>

                            <!-- ── Data Rows ── -->
                            <ItemsControl Grid.Row="1"
                                          x:Name="PerformanceTable">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="1.4*" />
                                                <ColumnDefinition Width="1.4*" />
                                                <ColumnDefinition Width="1.4*" />
                                                <ColumnDefinition Width="1.6*" />
                                                <ColumnDefinition Width="1.4*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Style="{StaticResource DataCellStyle}">
                                                <TextBlock Text="{Binding EmployeeName}"
                                                           Style="{StaticResource DataTextStyle}" />
                                            </Border>
                                            <Border Grid.Column="1" Style="{StaticResource DataCellStyle}">
                                                <TextBlock Text="{Binding Department}"
                                                           Style="{StaticResource DataTextStyle}" />
                                            </Border>
                                            <Border Grid.Column="2" Style="{StaticResource DataCellStyle}">
                                                <TextBlock Text="{Binding TaskSummary}"
                                                           Style="{StaticResource DataTextStyle}" />
                                            </Border>
                                            <Border Grid.Column="3" Style="{StaticResource DataCellStyle}">
                                                <TextBlock Text="{Binding AttendancePercent}"
                                                           Style="{StaticResource DataTextStyle}" />
                                            </Border>
                                            <Border Grid.Column="4" Style="{StaticResource DataCellStyle}">
                                                <TextBlock Text="{Binding PerformanceScore}"
                                                           Style="{StaticResource DataTextStyle}" />
                                            </Border>
                                            <!-- Status badge -->
                                            <Border Grid.Column="5" Style="{StaticResource DataCellStyle}">
                                                <Border Style="{StaticResource StatusBadgeStyle}"
                                                        Background="{Binding StatusColor}">
                                                    <TextBlock Text="{Binding Status}"
                                                               Foreground="White"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center" />
                                                </Border>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </Grid>
                    </Border>

                    <!-- Empty state -->
                    <TextBlock x:Name="EmptyLabel"
                               Text="No performance data available."
                               Foreground="#aaaaaa"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Margin="0,24,0,8"
                               Visibility="Collapsed" />

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
