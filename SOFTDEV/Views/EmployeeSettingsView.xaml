<UserControl x:Class="SOFTDEV.Views.EmployeeSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SOFTDEV.Views"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1400"
             Background="Transparent">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ScrollViewer.Resources>
            <Style TargetType="ScrollBar" BasedOn="{StaticResource CustomScrollbarStyle}" />
        </ScrollViewer.Resources>

        <Grid Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- Main Settings -->
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                
                <TextBlock Text="Settings"
                           Foreground="{StaticResource PurpleAccentBrush}"
                           FontWeight="Bold"
                           FontSize="28"
                           Margin="0,0,0,20" />

                <!-- Profile Settings -->
                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Padding="24"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Profile Information"
                                   Foreground="{StaticResource PurpleAccentBrush}"
                                   FontWeight="Bold"
                                   FontSize="18"
                                   Margin="0,0,0,20" />

                        <!-- Full Name -->
                        <TextBlock Text="Full Name"
                                   Foreground="#aaaaaa"
                                   FontSize="12"
                                   Margin="0,0,0,6" />
                        <TextBox x:Name="FullNameTextBox"
                                 Text="John Doe"
                                 Style="{StaticResource RoundedTextBoxStyle}"
                                 Margin="0,0,0,16" />

                        <!-- Email -->
                        <TextBlock Text="Email Address"
                                   Foreground="#aaaaaa"
                                   FontSize="12"
                                   Margin="0,0,0,6" />
                        <TextBox x:Name="EmailTextBox"
                                 Text="john.doe@company.com"
                                 Style="{StaticResource RoundedTextBoxStyle}"
                                 Margin="0,0,0,16" />

                        <!-- Phone -->
                        <TextBlock Text="Phone Number"
                                   Foreground="#aaaaaa"
                                   FontSize="12"
                                   Margin="0,0,0,6" />
                        <TextBox x:Name="PhoneTextBox"
                                 Text="+1 (555) 123-4567"
                                 Style="{StaticResource RoundedTextBoxStyle}"
                                 Margin="0,0,0,16" />

                        <!-- Department -->
                        <TextBlock Text="Department"
                                   Foreground="#aaaaaa"
                                   FontSize="12"
                                   Margin="0,0,0,6" />
                        <TextBox x:Name="DepartmentTextBox"
                                 Text="Engineering"
                                 Style="{StaticResource RoundedTextBoxStyle}"
                                 IsReadOnly="True"
                                 Margin="0,0,0,20" />

                        <Button Content="Save Changes"
                                Style="{StaticResource PillButtonStyle}"
                                Height="44"
                                HorizontalAlignment="Left"
                                Padding="32,0"
                                Click="SaveProfile_Click" />

                    </StackPanel>
                </Border>

                <!-- Password Settings -->
                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Padding="24"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Change Password"
                                   Foreground="{StaticResource PurpleAccentBrush}"
                                   FontWeight="Bold"
                                   FontSize="18"
                                   Margin="0,0,0,20" />

                        <!-- Current Password -->
                        <TextBlock Text="Current Password"
                                   Foreground="#aaaaaa"
                                   FontSize="12"
                                   Margin="0,0,0,6" />
                        <PasswordBox x:Name="CurrentPasswordBox"
                                     Style="{StaticResource RoundedPasswordBoxStyle}"
                                     Margin="0,0,0,16" />

                        <!-- New Password -->
                        <TextBlock Text="New Password"
                                   Foreground="#aaaaaa"
                                   FontSize="12"
                                   Margin="0,0,0,6" />
                        <PasswordBox x:Name="NewPasswordBox"
                                     Style="{StaticResource RoundedPasswordBoxStyle}"
                                     Margin="0,0,0,16" />

                        <!-- Confirm Password -->
                        <TextBlock Text="Confirm New Password"
                                   Foreground="#aaaaaa"
                                   FontSize="12"
                                   Margin="0,0,0,6" />
                        <PasswordBox x:Name="ConfirmPasswordBox"
                                     Style="{StaticResource RoundedPasswordBoxStyle}"
                                     Margin="0,0,0,20" />

                        <Button Content="Update Password"
                                Style="{StaticResource PillButtonStyle}"
                                Height="44"
                                HorizontalAlignment="Left"
                                Padding="32,0"
                                Click="UpdatePassword_Click" />

                    </StackPanel>
                </Border>

                <!-- Notification Preferences -->
                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Padding="24">
                    <StackPanel>
                        <TextBlock Text="Notification Preferences"
                                   Foreground="{StaticResource PurpleAccentBrush}"
                                   FontWeight="Bold"
                                   FontSize="18"
                                   Margin="0,0,0,20" />

                        <CheckBox Content="Email notifications for new tasks"
                                  Style="{StaticResource RoleCheckBoxStyle}"
                                  IsChecked="True"
                                  Margin="0,0,0,12" />

                        <CheckBox Content="Email notifications for leave approvals"
                                  Style="{StaticResource RoleCheckBoxStyle}"
                                  IsChecked="True"
                                  Margin="0,0,0,12" />

                        <CheckBox Content="Email notifications for performance reviews"
                                  Style="{StaticResource RoleCheckBoxStyle}"
                                  IsChecked="True"
                                  Margin="0,0,0,12" />

                        <CheckBox Content="Push notifications"
                                  Style="{StaticResource RoleCheckBoxStyle}"
                                  IsChecked="False"
                                  Margin="0,0,0,20" />

                        <Button Content="Save Preferences"
                                Style="{StaticResource PillButtonStyle}"
                                Height="44"
                                HorizontalAlignment="Left"
                                Padding="32,0"
                                Click="SavePreferences_Click" />

                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- Sidebar -->
            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                
                <!-- Profile Picture -->
                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Padding="24"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Profile Picture"
                                   Foreground="{StaticResource PurpleAccentBrush}"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Margin="0,0,0,16" />

                        <Border Width="120"
                                Height="120"
                                CornerRadius="60"
                                Background="{StaticResource PurpleAccentBrush}"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,16">
                            <TextBlock Text="👤"
                                       FontSize="60"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <Button Content="Upload Photo"
                                Style="{StaticResource OutlinePillButtonStyle}"
                                Height="40"
                                Click="UploadPhoto_Click" />

                    </StackPanel>
                </Border>

                <!-- Account Info -->
                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Padding="24">
                    <StackPanel>
                        <TextBlock Text="Account Information"
                                   Foreground="{StaticResource PurpleAccentBrush}"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Margin="0,0,0,16" />

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Employee ID"
                                       Foreground="#aaaaaa"
                                       FontSize="11" />
                            <TextBlock Text="EMP-2026-001"
                                       Foreground="White"
                                       FontSize="14"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Join Date"
                                       Foreground="#aaaaaa"
                                       FontSize="11" />
                            <TextBlock Text="January 15, 2024"
                                       Foreground="White"
                                       FontSize="14"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Position"
                                       Foreground="#aaaaaa"
                                       FontSize="11" />
                            <TextBlock Text="Senior Software Engineer"
                                       Foreground="White"
                                       FontSize="14"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Manager"
                                       Foreground="#aaaaaa"
                                       FontSize="11" />
                            <TextBlock Text="Jane Smith"
                                       Foreground="White"
                                       FontSize="14"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                    </StackPanel>
                </Border>

            </StackPanel>

        </Grid>

    </ScrollViewer>
</UserControl>
