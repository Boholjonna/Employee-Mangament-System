<Window x:Class="SOFTDEV.AdminEmployeesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SOFTDEV"
        mc:Ignorable="d"
        Title="Admin Employees"
        MinWidth="1200"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="CanResize"
        Background="{StaticResource DarkBackgroundBrush}"
        FontFamily="Segoe UI">

    <!-- ═══════════════════════════════════════════════════════════
         Top-level Grid: Row 0 = header/nav (Auto), Row 1 = content (*)
         ═══════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Row 0: Header + Nav Bar -->
            <RowDefinition Height="*"    />  <!-- Row 1: Main Content     -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             Row 0 — Header Section (control group + nav bar)
             ═══════════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="0" Orientation="Vertical">

            <!-- ─────────────────────────────────────────────────
                 TopNavBar — company logo left, control group right
                 ───────────────────────────────────────────────── -->
            <DockPanel Margin="20,16,20,8" LastChildFill="False">

                <!-- Left: Back button + Company name / logo -->
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Button x:Name="BackButton"
                            Style="{StaticResource CircleButtonStyle}"
                            Content="←"
                            Margin="0,0,12,0"
                            Click="BackButton_Click" />

                    <TextBlock Text="COMPANY NAME/LOGO"
                               Foreground="{StaticResource PurpleAccentBrush}"
                               FontWeight="Bold"
                               FontSize="18"
                               VerticalAlignment="Center" />

                </StackPanel>

                <!-- Right: Search, Notifications, Username, Avatar -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Button x:Name="SearchButton"
                            Style="{StaticResource CircleButtonStyle}"
                            Content="🔍"
                            Margin="0,0,8,0"
                            Click="SearchButton_Click" />

                    <Button x:Name="NotificationButton"
                            Style="{StaticResource CircleButtonStyle}"
                            Content="🔔"
                            Margin="0,0,8,0"
                            Click="NotificationButton_Click" />

                    <Button x:Name="UserNameButton"
                            Style="{StaticResource PillButtonStyle}"
                            Content="NAME"
                            Width="80"
                            Height="30"
                            Margin="0,0,8,0"
                            Click="UserNameButton_Click" />

                    <Button x:Name="AvatarButton"
                            Style="{StaticResource CircleButtonStyle}"
                            Content="👤"
                            Click="AvatarButton_Click" />

                </StackPanel>

            </DockPanel>

            <!-- ─────────────────────────────────────────────────
                 Navigation Bar — 7 equal-width buttons
                 ───────────────────────────────────────────────── -->
            <UniformGrid x:Name="NavBarPanel"
                         Rows="1"
                         Margin="20,0,20,16">

                <!-- Overview — inactive -->
                <Button x:Name="OverviewButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="▲ OVERVIEW"
                        Background="{StaticResource PurpleAccentBrush}"
                        Opacity="0.4"
                        Margin="0,0,4,0"
                        Click="NavButton_Click">
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="Button.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="1.0" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Button.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="0.4" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>

                <!-- Employees — ACTIVE tab -->
                <Button x:Name="EmployeesButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="Employees"
                        Background="{StaticResource PurpleAccentBrush}"
                        Opacity="1.0"
                        Margin="4,0,4,0"
                        Click="NavButton_Click" />

                <!-- Attendance — inactive -->
                <Button x:Name="AttendanceButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="Attendance"
                        Background="{StaticResource PurpleAccentBrush}"
                        Opacity="0.4"
                        Margin="4,0,4,0"
                        Click="NavButton_Click">
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="Button.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="1.0" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Button.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="0.4" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>

                <!-- To Do — inactive -->
                <Button x:Name="ToDoButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="To Do"
                        Background="{StaticResource PurpleAccentBrush}"
                        Opacity="0.4"
                        Margin="4,0,4,0"
                        Click="NavButton_Click">
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="Button.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="1.0" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Button.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="0.4" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>

                <!-- Reports — inactive -->
                <Button x:Name="ReportsButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="Reports"
                        Background="{StaticResource PurpleAccentBrush}"
                        Opacity="0.4"
                        Margin="4,0,4,0"
                        Click="NavButton_Click">
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="Button.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="1.0" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Button.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="0.4" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>

                <!-- Leaves — inactive -->
                <Button x:Name="LeavesButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="Leaves"
                        Background="{StaticResource PurpleAccentBrush}"
                        Opacity="0.4"
                        Margin="4,0,4,0"
                        Click="NavButton_Click">
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="Button.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="1.0" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Button.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="0.4" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>

                <!-- Settings — inactive -->
                <Button x:Name="SettingsButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="Settings"
                        Background="{StaticResource PurpleAccentBrush}"
                        Opacity="0.4"
                        Margin="4,0,0,0"
                        Click="NavButton_Click">
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="Button.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="1.0" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Button.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="0.4" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>

            </UniformGrid>

        </StackPanel>

        <!-- ═══════════════════════════════════════════════════════════
             Row 1 — Main Content Area
             ═══════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar"
                       BasedOn="{StaticResource CustomScrollbarStyle}" />
            </ScrollViewer.Resources>

            <Grid Margin="20,0,20,20">

                <!-- Primary card container -->
                <Border CornerRadius="25"
                        Background="#1e1e2d"
                        Padding="24">

                    <!-- Inner grid: Row 0 = card header, Row 1 = employee list -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />  <!-- Row 0: Card header -->
                            <RowDefinition Height="*"    />  <!-- Row 1: Employee list -->
                        </Grid.RowDefinitions>

                        <!-- ─────────────────────────────────────────────────
                             Row 0 — Card Header: title left, buttons right
                             ───────────────────────────────────────────────── -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"    />  <!-- Col 0: Title -->
                                <ColumnDefinition Width="Auto" />  <!-- Col 1: Action buttons -->
                            </Grid.ColumnDefinitions>

                            <!-- Section title -->
                            <TextBlock Grid.Column="0"
                                       Text="My Employees"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="20"
                                       VerticalAlignment="Center" />

                            <!-- Filter + Sort buttons -->
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">

                                <Button x:Name="FilterButton"
                                        Style="{StaticResource PillButtonStyle}"
                                        Content="FILTER ↓"
                                        MinWidth="100"
                                        Padding="16,8"
                                        Margin="0,0,8,0"
                                        Click="FilterButton_Click" />

                                <Button x:Name="SortButton"
                                        Style="{StaticResource PillButtonStyle}"
                                        Content="SORT ↓"
                                        MinWidth="90"
                                        Padding="16,8"
                                        Click="SortButton_Click" />

                            </StackPanel>
                        </Grid>

                        <!-- ─────────────────────────────────────────────────
                             Row 1 — Scrollable Employee List
                             ───────────────────────────────────────────────── -->
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ScrollViewer.Resources>
                                <Style TargetType="ScrollBar"
                                       BasedOn="{StaticResource CustomScrollbarStyle}" />
                            </ScrollViewer.Resources>

                            <ItemsControl x:Name="EmployeeListControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Employee row -->
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,8,0,8">

                                            <!-- Circular avatar -->
                                            <Border Width="44"
                                                    Height="44"
                                                    CornerRadius="22"
                                                    Background="{StaticResource PurpleAccentBrush}"
                                                    Margin="0,0,0,0">
                                                <TextBlock Text="👤"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>

                                            <!-- Name and position -->
                                            <StackPanel Orientation="Vertical"
                                                        VerticalAlignment="Center"
                                                        Margin="14,0,0,0">

                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="White"
                                                           FontWeight="Bold"
                                                           FontSize="15" />

                                                <TextBlock Text="{Binding Position}"
                                                           Foreground="#aaaaaa"
                                                           FontSize="12" />

                                            </StackPanel>

                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </ScrollViewer>

                    </Grid>
                </Border>

            </Grid>
        </ScrollViewer>

    </Grid>
</Window>
