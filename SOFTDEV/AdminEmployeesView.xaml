<Window x:Class="SOFTDEV.AdminEmployeesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SOFTDEV"
        mc:Ignorable="d"
        Title="Admin Employees"
        MinWidth="1200"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ResizeMode="CanResize"
        Background="{StaticResource DarkBackgroundBrush}"
        FontFamily="Segoe UI">

    <!-- ═══════════════════════════════════════════════════════════
         Top-level Grid: Row 0 = header/nav (Auto), Row 1 = content (*)
         ═══════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Row 0: Header + Nav Bar -->
            <RowDefinition Height="*"    />  <!-- Row 1: Main Content     -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             Row 0 — Header Section (control group + nav bar)
             ═══════════════════════════════════════════════════════════ -->
        <StackPanel Grid.Row="0" Orientation="Vertical">

            <!-- ─────────────────────────────────────────────────
                 TopNavBar — company logo left, control group right
                 ───────────────────────────────────────────────── -->
            <DockPanel Margin="20,16,20,8" LastChildFill="False">

                <!-- Left: Back button + Company name / logo -->
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Button x:Name="BackButton"
                            Style="{StaticResource CircleButtonStyle}"
                            Content="←"
                            Margin="0,0,12,0"
                            Click="BackButton_Click" />

                    <!-- Nexis Corp. logo -->
                    <Image Source="/images/nexis_logo.png"
                           Height="40"
                           Width="Auto"
                           VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality" />

                </StackPanel>

                <!-- Right: Search, Notifications, Username, Avatar -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Button x:Name="SearchButton"
                            Style="{StaticResource CircleButtonStyle}"
                            Content="🔍"
                            Margin="0,0,8,0"
                            Click="SearchButton_Click" />

                    <Button x:Name="NotificationButton"
                            Style="{StaticResource CircleButtonStyle}"
                            Content="🔔"
                            Margin="0,0,8,0"
                            Click="NotificationButton_Click" />

                    <Button x:Name="UserNameButton"
                            Style="{StaticResource PillButtonStyle}"
                            Content="NAME"
                            Width="80"
                            Height="30"
                            Margin="0,0,8,0"
                            Click="UserNameButton_Click" />

                    <Button x:Name="AvatarButton"
                            Style="{StaticResource CircleButtonStyle}"
                            Content="👤"
                            Click="AvatarButton_Click" />

                </StackPanel>

            </DockPanel>

            <!-- ─────────────────────────────────────────────────
                 Navigation Bar — 7 equal-width buttons
                 ───────────────────────────────────────────────── -->
            <UniformGrid x:Name="NavBarPanel"
                         Rows="1"
                         Margin="20,0,20,16">

                <!-- Overview — inactive -->
                <Button x:Name="OverviewButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="▲ OVERVIEW"
                        Background="{StaticResource PurpleAccentBrush}"
                        Opacity="0.4"
                        Margin="0,0,4,0"
                        Click="NavButton_Click">
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="Button.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="1.0" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Button.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="0.4" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>

                <!-- Employees — ACTIVE tab -->
                <Button x:Name="EmployeesButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="Employees"
                        Background="{StaticResource PurpleAccentBrush}"
                        Opacity="1.0"
                        Margin="4,0,4,0"
                        Click="NavButton_Click" />

                <!-- Attendance — inactive -->
                <Button x:Name="AttendanceButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="Attendance"
                        Background="{StaticResource PurpleAccentBrush}"
                        Opacity="0.4"
                        Margin="4,0,4,0"
                        Click="NavButton_Click">
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="Button.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="1.0" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Button.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="0.4" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>

                <!-- Task Management — inactive -->
                <Button x:Name="ToDoButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="Task Management"
                        Background="{StaticResource PurpleAccentBrush}"
                        Opacity="0.4"
                        Margin="4,0,4,0"
                        Click="NavButton_Click">
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="Button.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="1.0" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Button.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="0.4" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>

                <!-- Reports — inactive -->
                <Button x:Name="ReportsButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="Reports"
                        Background="{StaticResource PurpleAccentBrush}"
                        Opacity="0.4"
                        Margin="4,0,4,0"
                        Click="NavButton_Click">
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="Button.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="1.0" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Button.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="0.4" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>

                <!-- Leaves — inactive -->
                <Button x:Name="LeavesButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="Leaves"
                        Background="{StaticResource PurpleAccentBrush}"
                        Opacity="0.4"
                        Margin="4,0,4,0"
                        Click="NavButton_Click">
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="Button.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="1.0" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Button.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="0.4" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>

                <!-- Settings — inactive -->
                <Button x:Name="SettingsButton"
                        Style="{StaticResource PillButtonStyle}"
                        Content="Settings"
                        Background="{StaticResource PurpleAccentBrush}"
                        Opacity="0.4"
                        Margin="4,0,0,0"
                        Click="NavButton_Click">
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="Button.MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="1.0" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Button.MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="0.4" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>

            </UniformGrid>

        </StackPanel>

        <!-- ═══════════════════════════════════════════════════════════
             Row 1 — Main Content Area
             ═══════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar"
                       BasedOn="{StaticResource CustomScrollbarStyle}" />
            </ScrollViewer.Resources>

            <Grid Margin="20,0,20,20">

                <!-- Primary card container -->
                <Border CornerRadius="25"
                        Background="#1e1e2d"
                        Padding="24">

                    <!-- Two-column grid: Col 0 = employee list (300px), Col 1 = detail panel (*) -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300" />  <!-- Col 0: Employee list -->
                            <ColumnDefinition Width="*"   />  <!-- Col 1: Detail panel  -->
                        </Grid.ColumnDefinitions>

                        <!-- ═══════════════════════════════════════════════
                             Column 0 — Employee List Panel
                             ═══════════════════════════════════════════════ -->
                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />  <!-- Row 0: Card header -->
                                <RowDefinition Height="*"    />  <!-- Row 1: Employee list -->
                            </Grid.RowDefinitions>

                            <!-- ─────────────────────────────────────────────────
                                 Row 0 — Card Header: title left, buttons right
                                 ───────────────────────────────────────────────── -->
                            <Grid Grid.Row="0" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"    />  <!-- Col 0: Title -->
                                    <ColumnDefinition Width="Auto" />  <!-- Col 1: Action buttons -->
                                </Grid.ColumnDefinitions>

                                <!-- Section title -->
                                <TextBlock Grid.Column="0"
                                           Text="My Employees"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           FontSize="20"
                                           VerticalAlignment="Center" />

                                <!-- Filter + Sort buttons -->
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">

                                    <Button x:Name="FilterButton"
                                            Style="{StaticResource PillButtonStyle}"
                                            Content="FILTER ↓"
                                            MinWidth="100"
                                            Padding="16,8"
                                            Margin="0,0,8,0"
                                            Click="FilterButton_Click" />

                                    <Button x:Name="SortButton"
                                            Style="{StaticResource PillButtonStyle}"
                                            Content="SORT ↓"
                                            MinWidth="90"
                                            Padding="16,8"
                                            Click="SortButton_Click" />

                                </StackPanel>
                            </Grid>

                            <!-- ─────────────────────────────────────────────────
                                 Row 1 — Scrollable Employee List
                                 ───────────────────────────────────────────────── -->
                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ScrollViewer.Resources>
                                    <Style TargetType="ScrollBar"
                                           BasedOn="{StaticResource CustomScrollbarStyle}" />
                                </ScrollViewer.Resources>

                                <ItemsControl x:Name="EmployeeListControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <!-- Clickable Button wrapper — transparent chrome -->
                                            <Button Background="Transparent"
                                                    BorderThickness="0"
                                                    Padding="0"
                                                    HorizontalContentAlignment="Stretch"
                                                    Tag="{Binding Name}"
                                                    Click="EmployeeRow_Click">
                                                <!-- Employee row -->
                                                <StackPanel Orientation="Horizontal"
                                                            Margin="0,8,0,8">

                                                    <!-- Circular avatar -->
                                                    <Border Width="44"
                                                            Height="44"
                                                            CornerRadius="22"
                                                            Background="{StaticResource PurpleAccentBrush}"
                                                            Margin="0,0,0,0">
                                                        <TextBlock Text="👤"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Border>

                                                    <!-- Name and position -->
                                                    <StackPanel Orientation="Vertical"
                                                                VerticalAlignment="Center"
                                                                Margin="14,0,0,0">

                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="White"
                                                                   FontWeight="Bold"
                                                                   FontSize="15" />

                                                        <TextBlock Text="{Binding Position}"
                                                                   Foreground="#aaaaaa"
                                                                   FontSize="12" />

                                                    </StackPanel>

                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </ScrollViewer>

                        </Grid>

                        <!-- ═══════════════════════════════════════════════
                             Column 1 — Detail Panel (initially Collapsed)
                             ═══════════════════════════════════════════════ -->
                        <Border x:Name="DetailPanel"
                                Grid.Column="1"
                                Visibility="Collapsed"
                                Background="#1e1e2d"
                                CornerRadius="25"
                                Margin="16,0,0,0">

                            <Border Padding="24">
                            <StackPanel Orientation="Vertical">

                                <!-- Section title -->
                                <TextBlock Text="Employee Details"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           FontSize="18"
                                           Margin="0,0,0,16" />

                                <!-- Avatar + field grid wrapped in purple rounded card -->
                                <Border Background="{StaticResource PurpleAccentBrush}"
                                        CornerRadius="20"
                                        Padding="24">
                                <StackPanel Orientation="Horizontal">

                                    <!-- AvatarPlaceholder: 120×120 circle -->
                                    <Border Width="120"
                                            Height="120"
                                            CornerRadius="60"
                                            Background="#1e1e2d">
                                        <TextBlock Text="👤"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="48"
                                                   Foreground="White" />
                                    </Border>

                                    <!-- Label / value grid for all eight fields -->
                                    <Grid Margin="24,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />  <!-- labels -->
                                            <ColumnDefinition Width="*"    />  <!-- values -->
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />  <!-- Name -->
                                            <RowDefinition Height="Auto" />  <!-- Position -->
                                            <RowDefinition Height="Auto" />  <!-- Salary -->
                                            <RowDefinition Height="Auto" />  <!-- Payroll -->
                                            <RowDefinition Height="Auto" />  <!-- Date Hired -->
                                            <RowDefinition Height="Auto" />  <!-- Contact No. -->
                                            <RowDefinition Height="Auto" />  <!-- Address -->
                                            <RowDefinition Height="Auto" />  <!-- Emergency Contact -->
                                        </Grid.RowDefinitions>

                                        <!-- Row 0: Name -->
                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Text="Name"
                                                   Foreground="#1e1e2d"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Margin="0,0,0,8" />
                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Margin="12,0,0,8" />

                                        <!-- Row 1: Position -->
                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                   Text="Position"
                                                   Foreground="#1e1e2d"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Margin="0,0,0,8" />
                                        <TextBlock Grid.Row="1" Grid.Column="1"
                                                   Text="{Binding Position}"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   Margin="12,0,0,8" />

                                        <!-- Row 2: Salary -->
                                        <TextBlock Grid.Row="2" Grid.Column="0"
                                                   Text="Salary"
                                                   Foreground="#1e1e2d"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Margin="0,0,0,8" />
                                        <TextBlock Grid.Row="2" Grid.Column="1"
                                                   Text="{Binding Salary, StringFormat=₱{0:N2}}"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   Margin="12,0,0,8" />

                                        <!-- Row 3: Payroll -->
                                        <TextBlock Grid.Row="3" Grid.Column="0"
                                                   Text="Payroll"
                                                   Foreground="#1e1e2d"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Margin="0,0,0,8" />
                                        <TextBlock Grid.Row="3" Grid.Column="1"
                                                   Text="{Binding Payroll, StringFormat=₱{0:N2}}"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   Margin="12,0,0,8" />

                                        <!-- Row 4: Date Hired -->
                                        <TextBlock Grid.Row="4" Grid.Column="0"
                                                   Text="Date Hired"
                                                   Foreground="#1e1e2d"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Margin="0,0,0,8" />
                                        <TextBlock Grid.Row="4" Grid.Column="1"
                                                   Text="{Binding DateHired}"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   Margin="12,0,0,8" />

                                        <!-- Row 5: Contact No. -->
                                        <TextBlock Grid.Row="5" Grid.Column="0"
                                                   Text="Contact No."
                                                   Foreground="#1e1e2d"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Margin="0,0,0,8" />
                                        <TextBlock Grid.Row="5" Grid.Column="1"
                                                   Text="{Binding ContactNo}"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   Margin="12,0,0,8" />

                                        <!-- Row 6: Address -->
                                        <TextBlock Grid.Row="6" Grid.Column="0"
                                                   Text="Address"
                                                   Foreground="#1e1e2d"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Margin="0,0,0,8" />
                                        <TextBlock Grid.Row="6" Grid.Column="1"
                                                   Text="{Binding Address}"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   Margin="12,0,0,8" />

                                        <!-- Row 7: Emergency Contact -->
                                        <TextBlock Grid.Row="7" Grid.Column="0"
                                                   Text="Emergency Contact"
                                                   Foreground="#1e1e2d"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Margin="0,0,0,0" />
                                        <TextBlock Grid.Row="7" Grid.Column="1"
                                                   Text="{Binding EmergencyContact}"
                                                   Foreground="White"
                                                   FontSize="14"
                                                   Margin="12,0,0,0" />

                                    </Grid>

                                </StackPanel>
                                </Border>

                            </StackPanel>
                            </Border>

                        </Border>

                    </Grid>
                </Border>

            </Grid>
        </ScrollViewer>

    </Grid>
</Window>
